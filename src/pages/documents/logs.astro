---
import { supabaseAdmin } from '../../lib/supabase';
const user = Astro.locals.user;
const { data: logs } = await supabaseAdmin
  .from('export_logs')
  .select(`*, documents(document_number), tnc_users!export_logs_performed_by_fkey(full_name)`)
  .order('created_at', { ascending: false })
  .limit(100);

function thaiDate(s: string) {
  if (!s) return '—';
  return new Date(s).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });
}
const actionLabel: Record<string,string> = {
  view: 'เปิดดู', draft_saved: 'บันทึก Draft', published: 'ออกเอกสาร',
  pdf_exported: 'Export PDF', link_sent: 'ส่งลิงก์', cancelled: 'ยกเลิก'
};
const actionColor: Record<string,string> = {
  view: '#AEABA4', draft_saved: '#C9A96E', published: '#2D7A4F',
  pdf_exported: '#1a6fb5', link_sent: '#7B2D8B', cancelled: '#B94040'
};
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Export Logs — TNC Documents</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#F8F7F4;--white:#FFFFFF;--border:#E2DFD8;--border2:#EDE9E3;--text:#1A1814;--text2:#6B6860;--text3:#AEABA4;}
    body{font-family:'Plus Jakarta Sans','Noto Sans Thai',sans-serif;background:var(--bg);color:var(--text);}
    .topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 40px;height:60px;display:flex;align-items:center;gap:16px;position:sticky;top:0;}
    .back{font-size:12.5px;color:var(--text2);text-decoration:none;padding:6px 10px;border:1px solid var(--border);border-radius:4px;}
    .back:hover{border-color:var(--text);color:var(--text);}
    .topbar-title{font-size:15px;font-weight:600;}
    .content{padding:32px 40px;}
    .table-wrap{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden;}
    table{width:100%;border-collapse:collapse;}
    thead th{padding:9px 14px;text-align:left;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;background:var(--bg);border-bottom:1px solid var(--border);}
    tbody tr{border-bottom:1px solid var(--border2);}
    tbody tr:last-child{border-bottom:none;}
    td{padding:11px 14px;font-size:12.5px;color:var(--text2);}
    td.mono{font-family:monospace;font-size:11.5px;color:var(--text);}
    .action-badge{display:inline-block;padding:2px 8px;border-radius:2px;font-size:10.5px;font-weight:700;color:#fff;}
    .empty{padding:48px;text-align:center;color:var(--text3);}
  </style>
</head>
<body>
  <div class="topbar">
    <a href="/documents/dashboard" class="back">← กลับ</a>
    <div class="topbar-title">ประวัติการส่งออก (Export Logs)</div>
  </div>
  <div class="content">
    <div class="table-wrap">
      {!logs || logs.length === 0 ? (
        <div class="empty">ยังไม่มีประวัติการดำเนินการ</div>
      ) : (
        <table>
          <thead><tr>
            <th>วันที่/เวลา</th><th>เลขที่เอกสาร</th><th>การดำเนินการ</th><th>ผู้ดำเนินการ</th><th>หมายเหตุ</th>
          </tr></thead>
          <tbody>
            {logs.map((log: any) => (
              <tr>
                <td style="font-size:12px;white-space:nowrap;">{thaiDate(log.created_at)}</td>
                <td class="mono">{log.documents?.document_number || '—'}</td>
                <td>
                  <span class="action-badge" style={`background:${actionColor[log.action]||'#888'}`}>
                    {actionLabel[log.action] || log.action}
                  </span>
                </td>
                <td>{log.tnc_users?.full_name || '—'}</td>
                <td style="color:var(--text3);font-size:12px;">{log.notes || ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</body>
</html>
