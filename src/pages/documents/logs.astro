---
import { supabaseAdmin } from '../../lib/supabase';
const user = Astro.locals.user;
const { data: logs } = await supabaseAdmin
  .from('export_logs')
  .select(`*, documents(document_number), tnc_users!export_logs_performed_by_fkey(full_name)`)
  .order('created_at', { ascending: false })
  .limit(100);

function thaiDate(s: string) {
  if (!s) return '—';
  return new Date(s).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });
}
const actionLabel: Record<string,string> = {
  view:'เปิดดู', draft_saved:'บันทึก Draft', published:'ออกเอกสาร',
  pdf_exported:'Export PDF', link_sent:'ส่งลิงก์', cancelled:'ยกเลิก'
};
const actionColor: Record<string,string> = {
  view:'#AEABA4', draft_saved:'#C9A96E', published:'#2D7A4F',
  pdf_exported:'#1a6fb5', link_sent:'#7B2D8B', cancelled:'#B94040'
};
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Export Logs — TNC</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#F7F6F3;--white:#fff;--border:#E0DDD7;--b2:#ECEAE5;--text:#1A1814;--t2:#6B6860;--t3:#AEABA4;}
    body{font-family:'Plus Jakarta Sans','Noto Sans Thai',sans-serif;background:var(--bg);color:var(--text);}
    .topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 24px;height:54px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:10;}
    .back{font-size:12px;color:var(--t2);text-decoration:none;padding:7px 12px;border:1px solid var(--border);border-radius:5px;white-space:nowrap;-webkit-tap-highlight-color:transparent;}
    .back:active{background:var(--bg);}
    .topbar-title{font-size:15px;font-weight:700;flex:1;}
    .content{padding:20px 16px;}
    .card{background:var(--white);border:1px solid var(--border);border-radius:8px;overflow:hidden;}

    /* Desktop table */
    .tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
    table{width:100%;border-collapse:collapse;min-width:480px;}
    thead th{padding:10px 14px;text-align:left;font-size:9.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;background:var(--bg);border-bottom:1px solid var(--border);}
    tbody tr{border-bottom:1px solid var(--b2);}
    tbody tr:last-child{border-bottom:none;}
    td{padding:12px 14px;font-size:12.5px;color:var(--t2);}
    td.mono{font-family:monospace;font-size:12px;color:var(--text);}
    .badge{display:inline-block;padding:3px 9px;border-radius:4px;font-size:10.5px;font-weight:700;color:#fff;white-space:nowrap;}

    /* Mobile card list */
    .mob-list{display:none;}
    .mob-item{padding:14px 16px;border-bottom:1px solid var(--b2);}
    .mob-item:last-child{border-bottom:none;}
    .mob-row1{display:flex;align-items:center;gap:10px;margin-bottom:5px;}
    .mob-docnum{font-size:13px;font-weight:700;color:var(--text);flex:1;}
    .mob-date{font-size:11px;color:var(--t3);}
    .mob-row2{display:flex;align-items:center;gap:8px;}
    .mob-user{font-size:12px;color:var(--t2);}

    .empty{padding:48px 24px;text-align:center;color:var(--t3);}

    @media(max-width:600px){
      .topbar{padding:0 16px;}
      .topbar-title{font-size:13px;}
      .content{padding:14px 12px;}
      .tbl-wrap{display:none;}
      .mob-list{display:block;}
    }
  </style>
</head>
<body>
  <div class="topbar">
    <a href="/documents/dashboard" class="back">← กลับ</a>
    <div class="topbar-title">ประวัติการส่งออก (Export Logs)</div>
  </div>
  <div class="content">
    <div class="card">
      {!logs || logs.length === 0 ? (
        <div class="empty">ยังไม่มีประวัติการดำเนินการ</div>
      ) : (
        <>
          <div class="tbl-wrap">
            <table>
              <thead><tr>
                <th>วันที่/เวลา</th>
                <th>เลขที่เอกสาร</th>
                <th>การดำเนินการ</th>
                <th>ผู้ดำเนินการ</th>
                <th>หมายเหตุ</th>
              </tr></thead>
              <tbody>
                {logs.map((log: any) => (
                  <tr>
                    <td style="font-size:12px;white-space:nowrap;">{thaiDate(log.created_at)}</td>
                    <td class="mono">{log.documents?.document_number || '—'}</td>
                    <td><span class="badge" style={`background:${actionColor[log.action]||'#888'}`}>{actionLabel[log.action]||log.action}</span></td>
                    <td>{log.tnc_users?.full_name || '—'}</td>
                    <td style="color:var(--t3);font-size:12px;">{log.notes||''}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="mob-list">
            {logs.map((log: any) => (
              <div class="mob-item">
                <div class="mob-row1">
                  <span class="mob-docnum">{log.documents?.document_number || '—'}</span>
                  <span class="badge" style={`background:${actionColor[log.action]||'#888'}`}>{actionLabel[log.action]||log.action}</span>
                </div>
                <div class="mob-row2">
                  <span class="mob-user">{log.tnc_users?.full_name || '—'}</span>
                  <span style="color:var(--b2);">·</span>
                  <span class="mob-date">{thaiDate(log.created_at)}</span>
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  </div>
</body>
</html>
