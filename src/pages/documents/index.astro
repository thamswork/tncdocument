---
import { loginUser, createSession, getSessionUser, SESSION_COOKIE } from '../../lib/auth';
const token = Astro.cookies.get(SESSION_COOKIE)?.value;
const existingUser = await getSessionUser(token);
if (existingUser) return Astro.redirect('/documents/dashboard');
let error = '';
const returnUrl = Astro.url.searchParams.get('return') || '/documents/dashboard';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const user = await loginUser(form.get('username') as string, form.get('password') as string);
  if (user) {
    const t = await createSession(user.id);
    Astro.cookies.set(SESSION_COOKIE, t, { httpOnly: true, secure: true, sameSite: 'lax', maxAge: 28800, path: '/' });
    return Astro.redirect(returnUrl);
  }
  error = 'ชื่อผู้ใช้หรือรหัสผ่านไม่ถูกต้อง';
}
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="robots" content="noindex,nofollow"/>
  <title>เข้าสู่ระบบ — TNC Build Studio</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --bg:#F7F6F3;--white:#fff;--border:#E0DDD7;--b2:#ECEAE5;
      --text:#1A1814;--t2:#6B6860;--t3:#AEABA4;
      --gold:#C9A96E;--red:#B94040;
    }
    html,body{height:100%;font-family:'Plus Jakarta Sans','Noto Sans Thai',sans-serif;background:var(--bg);color:var(--text);}
    body{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100%;min-height:100dvh;padding:24px 20px;}

    .logo-area{text-align:center;margin-bottom:32px;}
    .logo-mark{width:48px;height:48px;background:var(--text);border-radius:10px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px;}
    .logo-mark svg{fill:var(--bg);width:24px;height:24px;}
    .brand-name{font-size:16px;font-weight:700;letter-spacing:.04em;color:var(--text);}
    .brand-sub{font-size:11px;color:var(--t3);letter-spacing:.08em;text-transform:uppercase;margin-top:2px;}

    .card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:32px 28px;width:100%;max-width:400px;box-shadow:0 4px 24px rgba(0,0,0,.06);}

    .card-title{font-size:20px;font-weight:700;margin-bottom:6px;}
    .card-sub{font-size:13px;color:var(--t2);margin-bottom:28px;}

    .fg{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
    .lbl{font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--t2);}
    .inp{padding:13px 14px;background:var(--bg);border:1.5px solid var(--border);border-radius:6px;font-size:15px;font-family:inherit;color:var(--text);outline:none;transition:border-color .2s;width:100%;-webkit-appearance:none;appearance:none;}
    .inp:focus{border-color:var(--text);background:var(--white);}
    .inp::placeholder{color:var(--t3);}

    .error{background:#FFF0F0;border:1px solid #F5C6C6;color:var(--red);padding:11px 14px;border-radius:6px;font-size:13px;margin-bottom:16px;display:flex;align-items:center;gap:8px;}

    .submit-btn{width:100%;padding:14px;background:var(--text);color:var(--bg);border:none;border-radius:6px;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;letter-spacing:.04em;text-transform:uppercase;transition:opacity .15s;margin-top:8px;-webkit-tap-highlight-color:transparent;min-height:50px;}
    .submit-btn:active{opacity:.85;}

    .back-link{margin-top:24px;font-size:12px;color:var(--t3);text-align:center;}
    .back-link a{color:var(--t2);text-decoration:none;}
    .back-link a:hover{color:var(--text);}

    @media(max-width:440px){
      .card{padding:24px 20px;border-radius:10px;}
      .card-title{font-size:18px;}
    }
  </style>
</head>
<body>

  <div class="logo-area">
    <div class="logo-mark">
      <svg viewBox="0 0 24 24"><path d="M19 3H5C3.9 3 3 3.9 3 5v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/></svg>
    </div>
    <div class="brand-name">TNC BUILD STUDIO</div>
    <div class="brand-sub">ระบบจัดการเอกสาร</div>
  </div>

  <div class="card">
    <div class="card-title">เข้าสู่ระบบ</div>
    <div class="card-sub">กรอกชื่อผู้ใช้และรหัสผ่านของคุณ</div>

    {error && (
      <div class="error">
        <span>⚠</span>
        <span>{error}</span>
      </div>
    )}

    <form method="POST" autocomplete="on">
      <div class="fg">
        <label class="lbl" for="username">ชื่อผู้ใช้</label>
        <input class="inp" type="text" id="username" name="username"
          placeholder="กรอกชื่อผู้ใช้"
          autocomplete="username"
          autocapitalize="none"
          autocorrect="off"
          spellcheck="false"
          required/>
      </div>
      <div class="fg">
        <label class="lbl" for="password">รหัสผ่าน</label>
        <input class="inp" type="password" id="password" name="password"
          placeholder="กรอกรหัสผ่าน"
          autocomplete="current-password"
          required/>
      </div>
      <button type="submit" class="submit-btn">เข้าสู่ระบบ</button>
    </form>
  </div>

  <div class="back-link">
    <a href="/">กลับสู่เว็บไซต์หลัก</a>
  </div>

</body>
</html>
