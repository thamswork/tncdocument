---
import { getDocuments } from '../../lib/documents';
const user = Astro.locals.user;
const documents = await getDocuments();

// Build linked invoices map: source_doc_id -> [linked IVs]
const linkedMap: Record<string, any[]> = {};
documents.forEach((doc: any) => {
  if (doc.source_document_id) {
    if (!linkedMap[doc.source_document_id]) linkedMap[doc.source_document_id] = [];
    linkedMap[doc.source_document_id].push(doc);
  }
});

const total = documents.length;
const drafts = documents.filter((d: any) => d.status === 'draft').length;
const published = documents.filter((d: any) => d.status === 'published').length;
const pendingAmt = documents
  .filter((d: any) => d.status === 'draft')
  .reduce((s: number, d: any) => s + (Number(d.total_amount)||0), 0);
const pendingFmt = pendingAmt.toLocaleString('th-TH', {minimumFractionDigits:0, maximumFractionDigits:0});
const docTypes = [...new Set(documents.map((d: any) => d.document_types?.code).filter(Boolean))];
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="default"/>
  <title>Dashboard — TNC Build Studio</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#F7F6F3;--white:#fff;--border:#E0DDD7;--b2:#ECEAE5;
      --text:#1A1814;--t2:#6B6860;--t3:#AEABA4;
      --gold:#C9A96E;--gbg:#FAF5EC;--gborder:#E8D5A8;
      --green:#2D7A4F;--red:#B94040;--blue:#2D5A9E;
      --sb:220px;
    }
    html{height:100%;}
    body{font-family:'Plus Jakarta Sans','Noto Sans Thai',sans-serif;background:var(--bg);color:var(--text);min-height:100%;display:flex;flex-direction:row;}

    /* ── Sidebar ── */
    .sidebar{width:var(--sb);background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100%;height:100dvh;z-index:200;transition:transform .25s cubic-bezier(.4,0,.2,1);}
    .sb-brand{padding:20px 20px 16px;border-bottom:1px solid var(--b2);}
    .sb-brand-name{font-size:13px;font-weight:700;letter-spacing:.04em;}
    .sb-brand-sub{font-size:10px;color:var(--t3);letter-spacing:.06em;text-transform:uppercase;margin-top:1px;}
    .sb-user{padding:14px 20px;border-bottom:1px solid var(--b2);}
    .sb-user-name{font-size:12.5px;font-weight:600;}
    .sb-user-role{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);margin-top:1px;}
    .sb-nav{padding:12px 0;flex:1;overflow-y:auto;}
    .sb-section{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);padding:8px 20px 4px;}
    .sb-link{display:flex;align-items:center;gap:10px;padding:11px 20px;font-size:13px;color:var(--t2);text-decoration:none;transition:background .12s;border-left:2px solid transparent;-webkit-tap-highlight-color:transparent;}
    .sb-link:hover,.sb-link:active{background:var(--bg);color:var(--text);}
    .sb-link.active{background:var(--gbg);color:var(--text);font-weight:600;border-left-color:var(--gold);}
    .sb-icon{font-size:15px;width:18px;text-align:center;flex-shrink:0;}
    .sb-bottom{padding:16px 20px;border-top:1px solid var(--b2);}
    .sb-logout{width:100%;padding:10px 12px;background:transparent;border:1px solid var(--border);border-radius:4px;font-size:12px;font-family:inherit;color:var(--t2);cursor:pointer;transition:all .15s;text-align:center;-webkit-tap-highlight-color:transparent;}
    .sb-logout:hover{border-color:var(--red);color:var(--red);}

    /* ── Overlay ── */
    .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:190;-webkit-tap-highlight-color:transparent;}
    .overlay.show{display:block;}

    /* ── Main ── */
    .main{margin-left:var(--sb);flex:1;display:flex;flex-direction:column;min-width:0;min-height:100dvh;}

    /* ── Topbar ── */
    .topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:100;}
    .hamburger{display:none;background:none;border:none;cursor:pointer;padding:8px;margin:-8px;flex-direction:column;justify-content:center;gap:5px;-webkit-tap-highlight-color:transparent;}
    .hamburger span{display:block;width:22px;height:2px;background:var(--text);border-radius:2px;transition:transform .2s,opacity .2s;}
    .tb-title{font-size:15px;font-weight:700;flex:1;}
    .btn{padding:9px 16px;border-radius:5px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer;border:none;letter-spacing:.04em;text-transform:uppercase;transition:all .15s;white-space:nowrap;text-decoration:none;display:inline-flex;align-items:center;gap:6px;-webkit-tap-highlight-color:transparent;min-height:40px;}
    .btn-solid{background:var(--text);color:var(--bg);}
    .btn-solid:active{opacity:.8;}
    .btn-ol{background:transparent;border:1px solid var(--border);color:var(--t2);}
    .btn-ol:active{background:var(--bg);}

    /* ── Content ── */
    .content{padding:24px;display:flex;flex-direction:column;gap:20px;flex:1;}

    /* ── Stats ── */
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
    .stat-card{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:18px 20px;cursor:pointer;transition:border-color .15s,transform .15s;-webkit-tap-highlight-color:transparent;}
    .stat-card:active{transform:scale(.98);}
    .stat-card.active{background:var(--gbg);border-color:var(--gold);}
    .stat-n{font-size:32px;font-weight:300;letter-spacing:-.03em;line-height:1;}
    .stat-n.gold{color:var(--gold);}
    .stat-label{font-size:10.5px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--t3);margin-top:6px;}
    .stat-sub{font-size:11px;color:var(--t3);margin-top:2px;}
    .stat-pending{font-size:11px;color:var(--gold);margin-top:5px;font-weight:600;}

    /* ── Table card ── */
    .table-card{background:var(--white);border:1px solid var(--border);border-radius:8px;overflow:hidden;}
    .table-toolbar{padding:14px 18px;border-bottom:1px solid var(--b2);display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
    .tb-info{flex:1;min-width:120px;}
    .tb-info-title{font-size:13px;font-weight:600;}
    .tb-info-sub{font-size:11px;color:var(--t3);margin-top:1px;}

    /* Search */
    .search-wrap{position:relative;}
    .search-ico{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:13px;pointer-events:none;}
    .search-inp{padding:8px 10px 8px 32px;background:var(--bg);border:1.5px solid var(--border);border-radius:5px;font-size:13px;font-family:inherit;color:var(--text);outline:none;transition:border-color .2s;width:200px;}
    .search-inp:focus{border-color:var(--text);}
    .search-inp::placeholder{color:var(--t3);}

    /* Filters */
    .filters{display:flex;gap:6px;align-items:center;}
    .filter-pill{padding:6px 14px;border-radius:20px;font-size:11.5px;font-weight:600;font-family:inherit;cursor:pointer;border:1.5px solid var(--border);background:transparent;color:var(--t2);transition:all .12s;white-space:nowrap;-webkit-tap-highlight-color:transparent;min-height:36px;}
    .filter-pill:active{opacity:.7;}
    .filter-pill.active{background:var(--text);border-color:var(--text);color:var(--bg);}
    .filter-pill.draft.active{background:#6B5B2E;border-color:#6B5B2E;color:#fff;}
    .filter-pill.published.active{background:var(--green);border-color:var(--green);color:#fff;}

    /* Table */
    .tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
    .tbl{width:100%;border-collapse:collapse;min-width:600px;}
    .tbl thead th{padding:10px 14px;font-size:9.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.09em;text-align:left;border-bottom:1px solid var(--b2);background:var(--bg);white-space:nowrap;cursor:pointer;user-select:none;}
    .tbl thead th.num{text-align:right;}
    .tbl tbody tr{border-bottom:1px solid var(--b2);cursor:pointer;transition:background .1s;-webkit-tap-highlight-color:transparent;}
    .tbl tbody tr:last-child{border-bottom:none;}
    .tbl tbody tr:hover,.tbl tbody tr:active{background:var(--gbg);}
    .tbl tbody tr.hidden{display:none;}
    .tbl td{padding:13px 14px;font-size:13px;vertical-align:middle;}
    .tbl td.num{text-align:right;font-variant-numeric:tabular-nums;}

    .doc-num{font-weight:700;font-size:13px;letter-spacing:.01em;}
    .badge{display:inline-flex;padding:3px 8px;border-radius:4px;font-size:9.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
    .badge-SV{background:#EBF0FA;color:#2D5A9E;}
    .badge-IV{background:#EBF5EE;color:#2D7A4F;}
    .badge-TX{background:#F5EBEB;color:#B94040;}
    .badge-BQ{background:var(--gbg);color:#8B6914;}
    .badge-default{background:var(--b2);color:var(--t2);}

    .status{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:600;}
    .sdot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
    .status-draft .sdot{background:var(--t3);}
    .status-draft{color:var(--t2);}
    .status-published .sdot{background:var(--green);}
    .status-published{color:var(--green);}

    .amt{font-weight:600;font-variant-numeric:tabular-nums;}
    .open-btn{color:var(--t3);font-size:12px;text-decoration:none;padding:6px 10px;border-radius:4px;transition:all .15s;white-space:nowrap;display:inline-block;-webkit-tap-highlight-color:transparent;}
    .open-btn:hover,.open-btn:active{color:var(--text);background:var(--b2);}

    .empty-row td{padding:48px 20px;text-align:center;color:var(--t3);}
    .empty-row-title{font-size:14px;font-weight:600;color:var(--t2);margin-bottom:4px;}
    .result-count{font-size:11px;color:var(--t3);padding:8px 18px;border-top:1px solid var(--b2);text-align:right;}
    .kbd{display:inline-block;background:var(--b2);border:1px solid var(--border);border-radius:3px;padding:1px 5px;font-size:9.5px;color:var(--t2);font-family:monospace;}

    /* ── Mobile ── */
    @media(max-width:768px){
      body{display:block;}
      .sidebar{transform:translateX(-100%);}
      .sidebar.open{transform:translateX(0);}
      .main{margin-left:0;}
      .hamburger{display:flex;}
      .topbar{padding:0 16px;gap:8px;}
      .tb-title{font-size:14px;}
      .btn{padding:8px 12px;font-size:11px;}
      .content{padding:16px;}
      .stats{grid-template-columns:1fr 1fr;}
      .stat-card{padding:14px 16px;}
      .stat-card:first-child{grid-column:1/-1;}
      .stat-n{font-size:26px;}
      .table-toolbar{flex-direction:column;align-items:stretch;gap:8px;padding:12px 14px;}
      .search-inp{width:100%!important;}
      .filters{overflow-x:auto;flex-wrap:nowrap;padding-bottom:2px;-webkit-overflow-scrolling:touch;}
      .tbl td{padding:12px 10px;font-size:12px;}
      .tbl thead th{padding:8px 10px;font-size:9px;}
      .tbl th:nth-child(7),.tbl td:nth-child(7){display:none;}
      .result-count{padding:6px 14px;}
      .kbd-hint{display:none;}
    }
    @media(max-width:480px){
      .stats{grid-template-columns:1fr;}
      .stat-card:first-child{grid-column:auto;}
      .tbl th:nth-child(2),.tbl td:nth-child(2){display:none;}
      .tbl th:nth-child(6),.tbl td:nth-child(6){display:none;}
      .tbl th:nth-child(5),.tbl td:nth-child(5){display:none;}
      /* make rows more tappable */
      .tbl td{padding:14px 10px;}
      .tbl tr{cursor:pointer;}
      .content{padding:12px;}
    }
  </style>
</head>
<body>

<div class="overlay" id="overlay"></div>

<nav class="sidebar" id="sidebar">
  <div class="sb-brand">
    <div class="sb-brand-name">TNC BUILD STUDIO</div>
    <div class="sb-brand-sub">ระบบเอกสาร</div>
  </div>
  <div class="sb-user">
    <div class="sb-user-name">{user.full_name}</div>
    <div class="sb-user-role">{user.role}</div>
  </div>
  <div class="sb-nav">
    <div class="sb-section">เมนูหลัก</div>
    <a href="/documents/dashboard" class="sb-link active"><span class="sb-icon">⊞</span> หน้าหลัก</a>
    <a href="/documents/new" class="sb-link"><span class="sb-icon">✦</span> สร้างเอกสารใหม่</a>
    <a href="/documents/customers" class="sb-link"><span class="sb-icon">◎</span> รายชื่อลูกค้า</a>
    {user.role === 'superadmin' && <a href="/documents/users" class="sb-link"><span class="sb-icon">◈</span> จัดการผู้ใช้งาน</a>}
    <a href="/documents/logs" class="sb-link"><span class="sb-icon">≡</span> ประวัติการส่งออก</a>
  </div>
  <div class="sb-bottom">
    <form method="POST" action="/documents/logout">
      <button type="submit" class="sb-logout">ออกจากระบบ</button>
    </form>
  </div>
</nav>

<div class="main">
  <div class="topbar">
    <button class="hamburger" id="hamburger" aria-label="เมนู">
      <span></span><span></span><span></span>
    </button>
    <div class="tb-title">ภาพรวมเอกสาร</div>
    <span class="kbd-hint" style="font-size:11px;color:var(--t3);">กด <span class="kbd">/</span> ค้นหา</span>
    <a href="/documents/customers/new" class="btn btn-ol">+ ลูกค้าใหม่</a>
    <a href="/documents/new" class="btn btn-solid">+ สร้างเอกสาร</a>
  </div>

  <div class="content">
    <div class="stats">
      <div class="stat-card active" id="stat-all" onclick="window.filterStatus('')">
        <div class="stat-n gold">{total}</div>
        <div class="stat-label">ทั้งหมด</div>
        <div class="stat-sub">ในระบบ</div>
      </div>
      <div class="stat-card" id="stat-draft" onclick="window.filterStatus('draft')">
        <div class="stat-n">{drafts}</div>
        <div class="stat-label">DRAFT</div>
        <div class="stat-sub">รอดำเนินการ</div>
        {pendingAmt > 0 && <div class="stat-pending">฿{pendingFmt} รอยืนยัน</div>}
      </div>
      <div class="stat-card" id="stat-published" onclick="window.filterStatus('published')">
        <div class="stat-n">{published}</div>
        <div class="stat-label">PUBLISHED</div>
        <div class="stat-sub">ออกเอกสารแล้ว</div>
      </div>
    </div>

    <div class="table-card">
      <div class="table-toolbar">
        <div class="tb-info">
          <div class="tb-info-title">เอกสารทั้งหมด</div>
          <div class="tb-info-sub">แตะที่แถวเพื่อเปิดเอกสาร</div>
        </div>
        <div class="search-wrap">
          <span class="search-ico">🔍</span>
          <input type="text" class="search-inp" id="searchInp"
            placeholder="ค้นหา..."
            oninput="window.doSearch(this.value)"
            autocomplete="off"/>
        </div>
        <div class="filters" id="typeFilters">
          <button class="filter-pill active" data-type="" onclick="window.filterType(this,'')">ทั้งหมด</button>
          {docTypes.map((code: any) => (
            <button class="filter-pill" data-type={code} onclick={`window.filterType(this,'${code}')`}>{code}</button>
          ))}
        </div>
        <div class="filters" id="statusFilters">
          <button class="filter-pill active" data-status="" onclick="window.filterStatus('')">ทุกสถานะ</button>
          <button class="filter-pill draft" data-status="draft" onclick="window.filterStatus('draft')">Draft</button>
          <button class="filter-pill published" data-status="published" onclick="window.filterStatus('published')">Published</button>
        </div>
      </div>

      <div class="tbl-wrap">
        <table class="tbl" id="docTable">
          <thead>
            <tr>
              <th onclick="window.sortBy('num')">เลขที่เอกสาร <span id="sort-num"></span></th>
              <th>ประเภท</th>
              <th onclick="window.sortBy('cust')">ชื่อลูกค้า <span id="sort-cust"></span></th>
              <th onclick="window.sortBy('date')">วันที่ออก <span id="sort-date">↓</span></th>
              <th class="num" onclick="window.sortBy('amt')">ยอดรวม (บาท) <span id="sort-amt"></span></th>
              <th>สถานะ</th>
              <th>ผู้สร้าง</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="docTbody">
            {documents.map((doc: any) => {
              const typeCode = doc.document_types?.code || '';
              const custName = doc.customers?.company_name || '-';
              const issueDate = doc.issue_date ? new Date(doc.issue_date).toLocaleDateString('th-TH', {day:'numeric',month:'short',year:'numeric'}) : '-';
              const amt = Number(doc.total_amount||0).toLocaleString('th-TH', {minimumFractionDigits:2, maximumFractionDigits:2});
              const rawAmt = Number(doc.total_amount||0);
              const issuedBy = doc.tnc_users?.full_name || '-';
              return (
                <tr onclick={`window.location.href='/documents/${doc.id}'`}
                  data-num={doc.document_number}
                  data-cust={custName}
                  data-type={typeCode}
                  data-status={doc.status}
                  data-date={doc.issue_date||''}
                  data-amt={rawAmt}>
                  <td><span class="doc-num">{doc.document_number}</span></td>
                  <td><span class={`badge badge-${typeCode||'default'}`}>{doc.document_types?.name_th || typeCode}</span></td>
                  <td>{custName}</td>
                  <td>{issueDate}</td>
                  <td class="num"><span class="amt">{amt}</span></td>
                  <td><span class={`status status-${doc.status}`}><span class="sdot"></span>{doc.status === 'draft' ? 'Draft' : 'Published'}</span></td>
                  <td style="font-size:11.5px;color:var(--t2);">{issuedBy}</td>
                  <td style="display:flex;align-items:center;gap:6px;">
                    {linkedMap[doc.id] && linkedMap[doc.id].length > 0 && (
                      <button onclick={`event.stopPropagation();toggleLinked('${doc.id}')`}
                        id={`exp-${doc.id}`}
                        style="background:var(--gbg);border:1px solid var(--gborder);border-radius:3px;padding:2px 6px;font-size:10px;font-weight:700;color:#8B6914;cursor:pointer;font-family:inherit;">
                        {linkedMap[doc.id].length} งวด ▾
                      </button>
                    )}
                    <a href={`/documents/${doc.id}`} class="open-btn" onclick="event.stopPropagation()">เปิด →</a>
                  </td>
                </tr>
                {linkedMap[doc.id] && linkedMap[doc.id].map((inv: any) => (
                    <tr id={`linked-${doc.id}`}
                      style="display:none;background:#FAF5EC;"
                      onclick={`window.location.href='/documents/${inv.id}'`}
                      data-linked="true">
                      <td style="padding-left:28px;">
                        <span style="color:var(--t3);font-size:10px;margin-right:4px;">↳</span>
                        <span class="doc-num" style="font-size:11.5px;">{inv.document_number}</span>
                      </td>
                      <td><span class="badge badge-INVOICE" style="font-size:10px;">งวด</span></td>
                      <td style="font-size:11.5px;color:var(--t2);">{inv.payment_condition||'—'}</td>
                      <td style="font-size:11.5px;">{inv.issue_date ? new Date(inv.issue_date).toLocaleDateString('th-TH',{day:'numeric',month:'short',year:'numeric'}) : '-'}</td>
                      <td class="num"><span class="amt" style="font-size:12px;">{Number(inv.total_amount||0).toLocaleString('th-TH',{minimumFractionDigits:2})}</span></td>
                      <td><span class={`status status-${inv.status}`}><span class="sdot"></span>{inv.status==='draft'?'Draft':'Published'}</span></td>
                      <td></td>
                      <td><a href={`/documents/${inv.id}`} class="open-btn" onclick="event.stopPropagation()">เปิด →</a></td>
                    </tr>
                ))}
            })}
          </tbody>
        </table>
      </div>
      <div class="result-count" id="resultCount"></div>
    </div>
  </div>
</div>

<script is:inline>
function toggleLinked(docId) {
  var rows = document.querySelectorAll('[id="linked-'+docId+'"]');
  var btn = document.getElementById('exp-'+docId);
  var isHidden = rows.length > 0 && rows[0].style.display === 'none';
  rows.forEach(function(r) { r.style.display = isHidden ? '' : 'none'; });
  if (btn) btn.innerHTML = isHidden ? btn.innerHTML.replace('▾','▴') : btn.innerHTML.replace('▴','▾');
}
// ── Sidebar toggle (must be on window scope) ──
window.toggleSidebar = function() {
  var sb = document.getElementById('sidebar');
  var ov = document.getElementById('overlay');
  sb.classList.toggle('open');
  ov.classList.toggle('show');
};
document.getElementById('hamburger').addEventListener('click', window.toggleSidebar);
document.getElementById('overlay').addEventListener('click', window.toggleSidebar);
document.querySelectorAll('.sb-link').forEach(function(l){
  l.addEventListener('click', function(){
    if(window.innerWidth <= 768) window.toggleSidebar();
  });
});

// ── Table logic ──
(function(){
  var searchVal='', typeVal='', statusVal='', sortCol='date', sortDir='desc';

  function applyFilters(){
    var rows = Array.from(document.querySelectorAll('#docTbody tr[data-num]'));
    var q = searchVal.toLowerCase().trim();
    var visible = 0;
    rows.forEach(function(row){
      var match = (!q || (row.dataset.num||'').toLowerCase().includes(q) || (row.dataset.cust||'').toLowerCase().includes(q) || (row.dataset.type||'').toLowerCase().includes(q))
        && (!typeVal || row.dataset.type === typeVal)
        && (!statusVal || row.dataset.status === statusVal);
      row.classList.toggle('hidden', !match);
      if(match) visible++;
    });
    var empty = document.getElementById('emptyRow');
    if(!visible){
      if(!empty){
        empty = document.createElement('tr');
        empty.id = 'emptyRow';
        empty.className = 'empty-row';
        empty.innerHTML = '<td colspan="8"><div class="empty-row-title">ไม่พบเอกสาร</div><div>ลองเปลี่ยนเงื่อนไขการค้นหา</div></td>';
        document.getElementById('docTbody').appendChild(empty);
      }
      empty.style.display = '';
    } else {
      if(empty) empty.style.display = 'none';
    }
    var total = rows.length;
    document.getElementById('resultCount').textContent = visible === total ? 'แสดง '+total+' รายการ' : 'แสดง '+visible+' จาก '+total+' รายการ';
  }

  function sortRows(){
    var tbody = document.getElementById('docTbody');
    var rows = Array.from(tbody.querySelectorAll('tr[data-num]'));
    rows.sort(function(a,b){
      if(sortCol==='amt'){ var d=(parseFloat(a.dataset.amt)||0)-(parseFloat(b.dataset.amt)||0); return sortDir==='asc'?d:-d; }
      var va='', vb='';
      if(sortCol==='date'){va=a.dataset.date||'';vb=b.dataset.date||'';}
      else if(sortCol==='num'){va=a.dataset.num||'';vb=b.dataset.num||'';}
      else if(sortCol==='cust'){va=a.dataset.cust||'';vb=b.dataset.cust||'';}
      return sortDir==='asc'?va.localeCompare(vb,'th'):vb.localeCompare(va,'th');
    });
    rows.forEach(function(r){tbody.appendChild(r);});
    ['num','cust','date','amt'].forEach(function(c){
      var el=document.getElementById('sort-'+c);
      if(!el) return;
      el.textContent = c===sortCol?(sortDir==='asc'?'↑':'↓'):'';
    });
  }

  window.doSearch = function(v){ searchVal=v; applyFilters(); };

  window.filterType = function(el, type){
    typeVal=type;
    document.querySelectorAll('#typeFilters .filter-pill').forEach(function(b){b.classList.remove('active');});
    el.classList.add('active');
    applyFilters();
  };

  window.filterStatus = function(status){
    statusVal=status;
    ['all','draft','published'].forEach(function(s){
      var el=document.getElementById('stat-'+s);
      if(el) el.classList.toggle('active',(s==='all'&&!status)||s===status);
    });
    document.querySelectorAll('#statusFilters .filter-pill').forEach(function(b){
      b.classList.toggle('active',(b.dataset.status||'')===status);
    });
    applyFilters();
  };

  window.sortBy = function(col){
    if(sortCol===col){sortDir=sortDir==='asc'?'desc':'asc';}
    else{sortCol=col;sortDir=col==='amt'?'desc':'asc';}
    sortRows(); applyFilters();
  };

  document.addEventListener('keydown', function(e){
    var inp=document.getElementById('searchInp');
    if(e.key==='/'&&document.activeElement!==inp){e.preventDefault();inp.focus();inp.select();}
    if(e.key==='Escape'){inp.value='';inp.blur();window.doSearch('');}
  });

  sortRows(); applyFilters();
})();
</script>
</body>
</html>
