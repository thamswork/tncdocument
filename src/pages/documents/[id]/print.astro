---
import { getDocument, logAction } from '../../../lib/documents';
const user = Astro.locals.user;
const { id } = Astro.params;
const doc = await getDocument(id!);
if (!doc) return Astro.redirect('/documents/dashboard');
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
await logAction(id!, 'pdf_exported', user.id);

function thaiDate(s: string) {
  if (!s) return '—';
  const d = new Date(s);
  const m = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
  return `${d.getDate()} ${m[d.getMonth()]} ${d.getFullYear()+543}`;
}
function fmt(n: number) {
  return Number(n||0).toLocaleString('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2});
}
function bahtText(amount: number): string {
  const ones=['','หนึ่ง','สอง','สาม','สี่','ห้า','หก','เจ็ด','แปด','เก้า'];
  const tens=['','สิบ','ยี่สิบ','สามสิบ','สี่สิบ','ห้าสิบ','หกสิบ','เจ็ดสิบ','แปดสิบ','เก้าสิบ'];
  function grp(n: number): string {
    if(n===0)return'';if(n<10)return ones[n];
    if(n<100)return tens[Math.floor(n/10)]+(n%10?ones[n%10]:'');
    return ones[Math.floor(n/100)]+'ร้อย'+grp(n%100);
  }
  const cents=Math.round(amount*100);const baht=Math.floor(cents/100);const satang=cents%100;
  if(baht===0&&satang===0)return'ศูนย์บาทถ้วน';
  let r='';
  if(baht>=1000000)r+=grp(Math.floor(baht/1000000))+'ล้าน';
  if(baht%1000000>=100000)r+=grp(Math.floor((baht%1000000)/100000))+'แสน';
  if(baht%100000>=10000)r+=grp(Math.floor((baht%100000)/10000))+'หมื่น';
  if(baht%10000>=1000)r+=grp(Math.floor((baht%10000)/1000))+'พัน';
  if(baht%1000>=100)r+=grp(Math.floor((baht%1000)/100))+'ร้อย';
  if(baht%100>0)r+=grp(baht%100);
  r+='บาท';r+=satang>0?grp(satang)+'สตางค์':'ถ้วน';
  return r;
}

// Build hierarchical structure: category > sub-category > items
// item_number format: "1" = category, "1.1" = sub-cat, "1.1.1" = item
const itemsByCategory: Record<string,any[]> = {};
doc.categories.forEach((cat: any) => {
  itemsByCategory[cat.id] = doc.items.filter((i: any) => i.category_id === cat.id);
});

const LOGO = 'https://res.cloudinary.com/dynjnftnu/image/upload/v1780149765/LOGO_TNC-03_0_liopw3.png';
const isQuotation = doc.document_types?.code === 'SV' || doc.document_types?.code === 'QT';
const isInvoice = doc.document_types?.code === 'IV' || doc.document_types?.code === 'IN';
---
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<meta name="robots" content="noindex,nofollow"/>
<title>{doc.document_number} — {doc.customers?.company_name}</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{font-family:'Sarabun',sans-serif;background:#CDD3DC;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
.toolbar{position:fixed;top:0;left:0;right:0;z-index:100;background:#0D1B2A;height:50px;padding:0 24px;display:flex;align-items:center;gap:12px;}
.tb-t{color:#ccc;font-size:13px;flex:1;}
.tbtn{padding:7px 16px;border-radius:3px;font-size:11px;font-weight:700;cursor:pointer;border:none;font-family:inherit;letter-spacing:.05em;text-transform:uppercase;text-decoration:none;display:inline-block;}
.t-back{background:transparent;color:#888;border:1px solid #444;margin-right:6px;}
.t-print{background:#112D5E;color:#fff;}
.page-wrap{padding-top:66px;padding-bottom:48px;text-align:center;}
.doc{display:inline-block;width:794px;text-align:left;background:#fff;box-shadow:0 6px 40px rgba(0,0,0,.22);}
.doc-inner{padding:28px 36px 44px;font-size:9pt;line-height:1.6;color:#0D1B2A;position:relative;}
.wm{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-20deg);font-size:110px;font-weight:900;color:rgba(0,0,0,.05);pointer-events:none;user-select:none;white-space:nowrap;z-index:1;}

/* Header */
.hdr{padding-bottom:12px;margin-bottom:14px;border-bottom:2.5px solid #112D5E;}
.hdr-inner{display:table;width:100%;border-collapse:collapse;}
.hdr-left{display:table-cell;vertical-align:top;width:60%;}
.hdr-right{display:table-cell;vertical-align:top;width:40%;text-align:right;}
.logo-img{width:150px;height:auto;margin-bottom:6px;}
.co-legal{font-size:8pt;font-weight:700;color:#0D1B2A;margin-bottom:2px;}
.co-addr{font-size:7.5pt;color:#444;line-height:1.7;}
.co-tax{font-size:7.5pt;color:#333;font-weight:600;margin-top:2px;}
.doctype-th{font-size:20pt;font-weight:700;color:#0D1B2A;display:block;line-height:1.05;}
.doctype-bar{background:#112D5E;color:#fff;font-size:7pt;font-weight:700;letter-spacing:.14em;text-transform:uppercase;display:block;padding:3px 10px;margin-top:4px;}
.draft-badge{display:inline-block;margin-top:8px;border:3px solid #C0392B;color:#C0392B;padding:3px 12px;font-size:12pt;font-weight:800;letter-spacing:.16em;transform:rotate(-8deg);border-radius:3px;}

/* Info grid */
.info-grid{width:100%;border-collapse:collapse;border:1.5px solid #112D5E;margin-bottom:14px;font-size:8.5pt;}
.info-grid td{padding:4px 9px;border:1px solid #ccc;vertical-align:top;line-height:1.6;}
.lbl{font-weight:700;color:#0D1B2A;white-space:nowrap;}
.val{color:#222;}
.mono{font-family:monospace;letter-spacing:.03em;}
.pay{white-space:pre-line;line-height:1.7;margin-top:3px;font-size:8pt;}
.valid-until{font-size:8pt;color:#B94040;font-weight:700;margin-top:4px;}

/* Items table */
.items{width:100%;border-collapse:collapse;margin-bottom:12px;font-size:8.5pt;}
.items th{background:#112D5E;color:#fff;padding:5px 7px;border:1px solid #0D1B2A;font-size:7.5pt;font-weight:600;text-align:center;white-space:nowrap;}
.items th.tl{text-align:left;}
.items td{padding:3px 7px;border:1px solid #ddd;vertical-align:middle;line-height:1.5;}
.items .tc{text-align:center;}
.items .tr{text-align:right;}
.items .tw{font-weight:600;}

/* Hierarchy rows */
.row-cat td{background:#112D5E;color:#fff;font-weight:700;font-size:9pt;padding:4px 8px;border-color:#222;}
.row-subcat td{background:#E8EDF5;color:#0D1B2A;font-weight:700;font-size:8.5pt;padding:4px 8px;border-color:#bbb;}
.row-item td{background:#fff;}
.row-item:nth-child(even) td{background:#fafafa;}
.row-sub td{background:#f0f0f0;font-weight:700;}
.sub-lbl{text-align:right!important;padding-right:12px!important;color:#333;}

/* Totals */
.totals-wrap{display:table;width:100%;margin-bottom:10px;}
.totals-tbl{display:table;margin-left:auto;border-collapse:collapse;min-width:240px;}
.totals-tbl tr td{padding:3px 10px;font-size:8.5pt;border-bottom:1px solid #eee;}
.totals-tbl .tl{color:#555;padding-right:20px;}
.totals-tbl .tv{text-align:right;font-weight:600;white-space:nowrap;}
.totals-tbl .grand td{border-top:2px solid #112D5E;border-bottom:none;font-weight:700;font-size:10.5pt;padding-top:6px;color:#0D1B2A;}
.amt-words{text-align:center;font-size:8pt;color:#555;border:1px solid #ddd;padding:5px 10px;background:#fafafa;margin-bottom:12px;}

/* Notes */
.notes{border-left:3px solid #112D5E;padding:7px 11px;margin-bottom:12px;background:#F5F8FF;}
.notes strong{display:block;font-size:8.5pt;font-weight:700;margin-bottom:3px;color:#0D1B2A;}
.notes p{font-size:8pt;color:#555;white-space:pre-line;line-height:1.7;}

/* Banking info */
.bank-box{border:1px solid #ddd;border-radius:3px;padding:8px 12px;margin-bottom:12px;background:#F9FBFF;display:table;width:100%;}
.bank-title{font-size:8pt;font-weight:700;color:#0D1B2A;margin-bottom:5px;border-bottom:1px solid #ddd;padding-bottom:4px;}
.bank-grid{display:table;width:100%;font-size:8pt;}
.bank-col{display:table-cell;width:50%;vertical-align:top;line-height:1.8;}
.bank-lbl{color:#777;font-size:7.5pt;}
.bank-val{color:#0D1B2A;font-weight:600;}
.bank-acc{font-size:10pt;font-weight:700;color:#112D5E;letter-spacing:.04em;}

/* Signatures */
.sig-note{text-align:center;font-size:7.5pt;color:#999;padding:6px 0;border-top:1px solid #e0e0e0;margin-top:12px;margin-bottom:10px;}
.sig-row{display:table;width:100%;}
.sig-cell{display:table-cell;text-align:center;padding:0 20px;width:50%;}
.sig-line{border-top:1px solid #bbb;margin:30px 8px 6px;}
.sig-lbl{font-size:7pt;color:#999;line-height:1.9;}

@media print{
  html,body{background:#fff;}
  .toolbar{display:none!important;}
  .page-wrap{padding:0;text-align:left;}
  .doc{width:210mm;display:block;box-shadow:none;}
  .doc-inner{padding:10mm 12mm 16mm;}
  .wm{position:absolute;}
  @page{size:A4 portrait;margin:0;}
}
</style>
</head>
<body>

<div class="toolbar">
  <div class="tb-t">
    <strong style="color:#fff;">{doc.document_number}</strong>
    <span style="color:#555;margin:0 8px;">—</span>
    <span style="color:#888;font-size:12px;">{doc.customers?.company_name}</span>
  </div>
  <a href={`/documents/${id}`} class="tbtn t-back">← กลับ</a>
  <button class="tbtn t-print" onclick="window.print()">พิมพ์ / บันทึก PDF</button>
</div>

<div class="page-wrap">
<div class="doc">
<div class="doc-inner">

  {doc.status==='draft' && <div class="wm">DRAFT</div>}

  <!-- Header -->
  <div class="hdr">
    <div class="hdr-inner">
      <div class="hdr-left">
        <img class="logo-img" src={LOGO} alt="TNC Build Studio"/>
        <div class="co-legal">ห้างหุ้นส่วนจำกัด ธนชัย 2018 (สำนักงานใหญ่)</div>
        <div class="co-addr">
          54/6 หมู่ 8 ตำบลบางแก้ว อำเภอบางพลี จังหวัดสมุทรปราการ 10540<br/>
          โทรศัพท์ 02-XXX-XXXX &emsp; อีเมล: thanachai2018@gmail.com
        </div>
        <div class="co-tax">เลขประจำตัวผู้เสียภาษีอากร 0113561003884</div>
      </div>
      <div class="hdr-right">
        <div>
          <span class="doctype-th">{doc.document_types?.name_th}</span>
          <span class="doctype-bar">{doc.document_types?.name_en || doc.document_types?.code}</span>
        </div>
        {doc.status==='draft' && <div><div class="draft-badge">DRAFT</div></div>}
      </div>
    </div>
  </div>

  <!-- Customer info -->
  <table class="info-grid">
    <tr>
      <td style="width:50%">
        <span class="lbl">รหัสลูกค้า: </span>
        <span class="val mono">{doc.customers?.customer_code}</span>
      </td>
      <td style="width:50%">
        <span class="lbl">วันที่ / Date: </span>
        <span class="val">{thaiDate(doc.issue_date)}</span>
      </td>
    </tr>
    <tr>
      <td colspan="2">
        <span class="lbl">ชื่อลูกค้า: </span>
        <span class="val">{doc.customers?.company_name}</span>
      </td>
    </tr>
    <tr>
      <td>
        <span class="lbl">ที่อยู่: </span>
        <span class="val">{doc.customers?.address || '—'}</span>
      </td>
      <td>
        <div><span class="lbl">เลขที่เอกสาร / No: </span><span class="val mono">{doc.document_number}</span></div>
        {doc.reference_po && <div><span class="lbl">เลขที่ P/O: </span><span class="val mono">{doc.reference_po}</span></div>}
        {isInvoice && doc.due_date && (
          <div><span class="lbl">กำหนดชำระ / Due: </span><span class="val">{thaiDate(doc.due_date)}</span></div>
        )}
        {doc.payment_condition && (
          <div style="margin-top:4px;">
            <div class="lbl">เงื่อนไขการชำระเงิน / Condition:</div>
            <div class="pay">{doc.payment_condition}</div>
          </div>
        )}
        {isQuotation && doc.due_date && (
          <div class="valid-until">⚠ ราคานี้มีผลถึง / Valid Until: {thaiDate(doc.due_date)}</div>
        )}
      </td>
    </tr>
    <tr>
      <td>
        <span class="lbl">โทรศัพท์: </span><span class="val">{doc.customers?.phone||'—'}</span>
        &emsp;
        <span class="lbl">แฟกซ์: </span><span class="val">{doc.customers?.fax||'—'}</span>
      </td>
      <td>
        <span class="lbl">เลขประจำตัวผู้เสียภาษี: </span>
        <span class="val mono">{doc.customers?.tax_id||'—'}</span>
      </td>
    </tr>
  </table>

  <!-- Items table with hierarchy -->
  <table class="items">
    <thead>
      <tr>
        <th style="width:32px;">ลำดับ</th>
        <th style="width:40px;">รหัส</th>
        <th class="tl">รายการ</th>
        <th style="width:48px;">จำนวน</th>
        <th style="width:40px;">หน่วย</th>
        <th style="width:80px;">หน่วยละ</th>
        <th style="width:88px;">จำนวนเงิน</th>
      </tr>
    </thead>
    <tbody>
      {doc.categories.map((cat: any) => {
        const items = itemsByCategory[cat.id] || [];
        const catTotal = items.filter((i:any)=>!i.is_subtotal_row).reduce((s:number,i:any)=>s+Number(i.amount||0),0);

        // Group items by sub-category (items whose item_number has 2 dots = sub-item)
        // item_number "1" = category label row, "1.1" = sub-cat, "1.1.1" = item
        // We render based on depth of item_number dots
        return (
          <Fragment>
            {/* Category row */}
            <tr class="row-cat">
              <td colspan="6">{cat.category_number}. {cat.name_th}</td>
              <td class="tr">{fmt(catTotal)}</td>
            </tr>
            {items.map((item: any) => {
              if (item.is_subtotal_row) return (
                <tr class="row-sub">
                  <td colspan="6" class="sub-lbl">{item.description_th}</td>
                  <td class="tr tw">{fmt(item.amount)}</td>
                </tr>
              );
              // Detect sub-category rows: qty=0, price=0, amount=0 and item_number has 1 dot
              const dots = (item.item_number||'').split('.').length - 1;
              const isSubCat = dots === 1 && !item.quantity && !item.unit_price;
              if (isSubCat) return (
                <tr class="row-subcat">
                  <td>{item.item_number}</td>
                  <td>{item.item_code||''}</td>
                  <td colspan="5">{item.description_th}</td>
                </tr>
              );
              return (
                <tr class="row-item">
                  <td class="tc">{item.item_number||''}</td>
                  <td class="tc">{item.item_code||''}</td>
                  <td style={dots>=2?'padding-left:20px;':''}>
                    {item.description_th}
                  </td>
                  <td class="tr">{item.quantity>0?Number(item.quantity).toLocaleString('th-TH'):'—'}</td>
                  <td class="tc">{item.unit_th||''}</td>
                  <td class="tr">{item.unit_price>0?fmt(item.unit_price):'—'}</td>
                  <td class="tr tw">{item.amount>0?fmt(item.amount):'—'}</td>
                </tr>
              );
            })}
          </Fragment>
        );
      })}
    </tbody>
  </table>

  <!-- Totals -->
  <div class="totals-wrap">
    <table class="totals-tbl">
      <tr><td class="tl">รวมจำนวนเงิน</td><td class="tv">{fmt(doc.subtotal)} บาท</td></tr>
      {doc.discount_design>0 && <tr><td class="tl">ส่วนลดค่าแบบ</td><td class="tv">- {fmt(doc.discount_design)} บาท</td></tr>}
      {doc.discount_trade>0 && <tr><td class="tl">ส่วนลดการค้า</td><td class="tv">- {fmt(doc.discount_trade)} บาท</td></tr>}
      <tr><td class="tl">ราคาสินค้า/บริการ</td><td class="tv">{fmt(doc.price_before_vat)} บาท</td></tr>
      <tr><td class="tl">ภาษีมูลค่าเพิ่ม 7%</td><td class="tv">{fmt(doc.vat_amount)} บาท</td></tr>
      <tr class="grand"><td class="tl">จำนวนเงินรวมทั้งสิ้น</td><td class="tv">{fmt(doc.total_amount)} บาท</td></tr>
    </table>
  </div>
  <div class="amt-words">จำนวนเงินเป็นตัวหนังสือ: {bahtText(doc.total_amount)}</div>

  {doc.notes && (
    <div class="notes">
      <strong>หมายเหตุ / Remarks</strong>
      <p>{doc.notes}</p>
    </div>
  )}

  <!-- Banking information -->
  <div class="bank-box">
    <div class="bank-title">ข้อมูลการชำระเงิน / Payment Information</div>
    <div class="bank-grid">
      <div class="bank-col">
        <div><span class="bank-lbl">ธนาคาร / Bank: </span><span class="bank-val">ธนาคารกสิกรไทย (Kasikorn Bank)</span></div>
        <div><span class="bank-lbl">สาขา / Branch: </span><span class="bank-val">เมกา บางนา 2 (Mega Bangna 2)</span></div>
        <div><span class="bank-lbl">Swift Code: </span><span class="bank-val">KASITHBK</span></div>
        <div><span class="bank-lbl">รหัสธนาคาร / Bank Code: </span><span class="bank-val">004</span></div>
      </div>
      <div class="bank-col">
        <div><span class="bank-lbl">ประเภทบัญชี / Account Type: </span><span class="bank-val">ออมทรัพย์ (Saving)</span></div>
        <div><span class="bank-lbl">ชื่อบัญชี / Account Name: </span><span class="bank-val">ห้างหุ้นส่วนจำกัด ธนชัย 2018</span></div>
        <div style="margin-top:3px;"><span class="bank-lbl">เลขที่บัญชี / Account No: </span><span class="bank-acc">051-1-72646-8</span></div>
      </div>
    </div>
  </div>

  <!-- Signatures -->
  <div class="sig-note">ห้างหุ้นส่วนจำกัด ธนชัย 2018 หวังว่าจะได้รับการพิจารณาจากท่าน</div>
  <div class="sig-row">
    <div class="sig-cell">
      <div class="sig-line"></div>
      <div class="sig-lbl">ลงชื่อผู้เสนอราคา ........................................<br/>วันที่ ......../......../........</div>
    </div>
    <div class="sig-cell">
      <div class="sig-line"></div>
      <div class="sig-lbl">ลงชื่อผู้สั่งซื้อ ........................................<br/>วันที่ ......../......../........</div>
    </div>
  </div>

</div>
</div>
</div>
</body>
</html>
