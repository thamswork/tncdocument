---
import { getDocument, logAction } from '../../../lib/documents';
const user = Astro.locals.user;
const { id } = Astro.params;
const doc = await getDocument(id!);
if (!doc) return Astro.redirect('/documents/dashboard');
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
await logAction(id!, 'pdf_exported', user.id);
function thaiDate(s: string) {
  if (!s) return '—';
  const d = new Date(s);
  const m = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
  return `${d.getDate()} ${m[d.getMonth()]} ${d.getFullYear()+543}`;
}
function fmt(n: number) {
  return Number(n||0).toLocaleString('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2});
}
function bahtText(amount: number): string {
  const ones=['','หนึ่ง','สอง','สาม','สี่','ห้า','หก','เจ็ด','แปด','เก้า'];
  const tens=['','สิบ','ยี่สิบ','สามสิบ','สี่สิบ','ห้าสิบ','หกสิบ','เจ็ดสิบ','แปดสิบ','เก้าสิบ'];
  function grp(n: number): string {
    if(n===0)return'';if(n<10)return ones[n];
    if(n<100)return tens[Math.floor(n/10)]+(n%10?ones[n%10]:'');
    return ones[Math.floor(n/100)]+'ร้อย'+grp(n%100);
  }
  const cents=Math.round(amount*100);const baht=Math.floor(cents/100);const satang=cents%100;
  if(baht===0&&satang===0)return'ศูนย์บาทถ้วน';
  let r='';
  if(baht>=1000000)r+=grp(Math.floor(baht/1000000))+'ล้าน';
  if(baht%1000000>=100000)r+=grp(Math.floor((baht%1000000)/100000))+'แสน';
  if(baht%100000>=10000)r+=grp(Math.floor((baht%100000)/10000))+'หมื่น';
  if(baht%10000>=1000)r+=grp(Math.floor((baht%10000)/1000))+'พัน';
  if(baht%1000>=100)r+=grp(Math.floor((baht%1000)/100))+'ร้อย';
  if(baht%100>0)r+=grp(baht%100);
  r+='บาท';r+=satang>0?grp(satang)+'สตางค์':'ถ้วน';
  return r;
}
const itemsByCategory: Record<string,any[]> = {};
doc.categories.forEach((cat: any) => {
  itemsByCategory[cat.id] = doc.items.filter((i: any) => i.category_id === cat.id);
});
const isQuotation = ['SV','QT','QUOTATION'].includes(doc.document_types?.code);
const isInvoice = ['IV','IN','INVOICE'].includes(doc.document_types?.code);
const LOGO = 'https://res.cloudinary.com/dynjnftnu/image/upload/v1780149765/LOGO_TNC-03_0_liopw3.png';
---
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>{doc.document_number}</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
html,body{font-family:'Sarabun',sans-serif;-webkit-print-color-adjust:exact;print-color-adjust:exact;background:#BFC5CE;}
/* toolbar */
.toolbar{position:fixed;top:0;left:0;right:0;z-index:100;background:#0D1B2A;height:50px;padding:0 24px;display:flex;align-items:center;gap:12px;}
.tb-t{color:#ccc;font-size:13px;flex:1;}
.tbtn{padding:7px 16px;border-radius:3px;font-size:11px;font-weight:700;cursor:pointer;border:none;font-family:inherit;letter-spacing:.05em;text-transform:uppercase;text-decoration:none;display:inline-block;}
.t-back{background:transparent;color:#888;border:1px solid #444;margin-right:6px;}
.t-print{background:#112D5E;color:#fff;}
/* screen wrapper */
.wrap{padding:66px 0 48px;display:flex;flex-direction:column;align-items:center;gap:0;}
/* the document - single continuous block, browser handles page breaks on print */
.sheet{width:210mm;background:#fff;box-shadow:0 2px 24px rgba(0,0,0,.22);padding:16mm 18mm 14mm;font-size:9.5pt;color:#0D1B2A;position:relative;}
.wm{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-25deg);font-size:100px;font-weight:900;color:rgba(0,0,0,.04);pointer-events:none;user-select:none;white-space:nowrap;}
/* page break line on screen */
.sheet{background-image:repeating-linear-gradient(to bottom,transparent calc(297mm - 2px),#BFC5CE calc(297mm - 2px),#BFC5CE 297mm,transparent 297mm);}
/* header */
.hdr{display:table;width:100%;border-collapse:collapse;padding-bottom:12px;margin-bottom:14px;border-bottom:3px solid #112D5E;}
.hdr-l{display:table-cell;vertical-align:middle;width:60%;}
.hdr-r{display:table-cell;vertical-align:top;width:40%;text-align:right;}
.logo{width:170px;height:auto;display:block;margin-bottom:8px;}
.co-name{font-size:9pt;font-weight:700;color:#0D1B2A;margin-bottom:3px;}
.co-addr{font-size:8pt;color:#555;line-height:1.8;}
.co-tax{font-size:8pt;color:#333;font-weight:600;margin-top:3px;}
.doc-type{font-size:22pt;font-weight:700;color:#0D1B2A;display:block;line-height:1;}
.doc-bar{background:#112D5E;color:#fff;font-size:7.5pt;font-weight:700;letter-spacing:.14em;text-transform:uppercase;display:inline-block;padding:3px 12px;margin-top:5px;}
.draft-stamp{display:inline-block;margin-top:10px;border:3px solid #C0392B;color:#C0392B;padding:3px 14px;font-size:13pt;font-weight:900;letter-spacing:.18em;transform:rotate(-8deg);border-radius:3px;}
/* info grid */
.info-tbl{width:100%;border-collapse:collapse;border:2px solid #112D5E;margin-bottom:14px;font-size:9pt;}
.info-tbl td{padding:5px 10px;border:1px solid #ccc;vertical-align:top;line-height:1.7;}
.lbl{font-weight:700;color:#0D1B2A;white-space:nowrap;}
.val{color:#222;}
.mono{font-family:monospace;letter-spacing:.03em;}
.pay{white-space:pre-line;line-height:1.7;margin-top:3px;font-size:8.5pt;}
.valid-until{font-size:8.5pt;color:#B94040;font-weight:700;margin-top:4px;}
/* items */
.items{width:100%;border-collapse:collapse;margin-bottom:14px;font-size:9pt;}
.items thead{display:table-header-group;}
.items th{background:#112D5E;color:#fff;padding:6px 8px;border:1px solid #0D1B2A;font-size:8pt;font-weight:600;text-align:center;white-space:nowrap;}
.items th.tl{text-align:left;}
.items td{padding:4px 8px;border:1px solid #ddd;vertical-align:middle;line-height:1.6;}
.tc{text-align:center;}.tr{text-align:right;}.tw{font-weight:600;}
.row-cat td{background:#112D5E;color:#fff;font-weight:700;font-size:10pt;padding:5px 8px;border-color:#0D1B2A;}
.row-subcat td{background:#E8EDF5;color:#0D1B2A;font-weight:700;padding:4px 8px;border-color:#bbb;}
.row-item td{background:#fff;}
.row-item:nth-child(even) td{background:#f9f9f9;}
.row-sub td{background:#efefef;font-weight:700;}
.sub-lbl{text-align:right!important;padding-right:14px!important;color:#444;}
/* totals */
.tot-wrap{display:table;width:100%;margin-bottom:8px;}
.tot-tbl{display:table;margin-left:auto;border-collapse:collapse;min-width:260px;}
.tot-tbl td{padding:3px 10px;font-size:9pt;border-bottom:1px solid #eee;}
.tt-l{color:#555;padding-right:24px;}
.tt-r{text-align:right;font-weight:600;white-space:nowrap;}
.grand td{border-top:2px solid #112D5E;border-bottom:none;font-weight:700;font-size:11pt;padding-top:7px;color:#0D1B2A;}
.baht-words{text-align:center;font-size:8.5pt;color:#555;border:1px solid #ddd;padding:5px 12px;background:#fafafa;margin-bottom:12px;}
/* notes */
.notes-box{border-left:3px solid #112D5E;padding:8px 12px;margin-bottom:12px;background:#F5F8FF;}
.notes-box strong{display:block;font-size:9pt;font-weight:700;margin-bottom:3px;color:#0D1B2A;}
.notes-box p{font-size:8.5pt;color:#555;white-space:pre-line;line-height:1.7;}
/* sig */
.sig-note{text-align:center;font-size:8pt;color:#999;padding:6px 0;border-top:1px solid #e0e0e0;margin:10px 0 8px;}
.sig-row{display:table;width:100%;table-layout:fixed;}
.sig-cell{display:table-cell;text-align:center;padding:0 24px;width:50%;}
.sig-line{border-top:1px solid #bbb;margin:30px 8px 7px;}
.sig-lbl{font-size:7.5pt;color:#999;line-height:2;}
/* bank */
.bank-wrap{margin-top:14px;padding-top:12px;border-top:2px solid #112D5E;}
.bank-box{border:1.5px solid #112D5E;border-radius:3px;padding:10px 14px;background:#EEF3FF;}
.bank-title{font-size:9.5pt;font-weight:700;color:#0D1B2A;margin-bottom:7px;border-bottom:1px solid #c0c8e0;padding-bottom:5px;}
.bank-cols{display:table;width:100%;table-layout:fixed;}
.bank-col{display:table-cell;width:50%;vertical-align:top;font-size:8.5pt;line-height:2;}
.bank-lbl{color:#666;}
.bank-val{color:#0D1B2A;font-weight:600;}
.bank-acc{font-size:11pt;font-weight:700;color:#112D5E;letter-spacing:.06em;}
/* print */
@media print{
  html,body{background:#fff;}
  .toolbar{display:none!important;}
  .wrap{padding:0;}
  .sheet{box-shadow:none;padding:12mm 14mm 10mm;background-image:none;}
  .items thead{display:table-header-group;}
  .row-cat{page-break-after:avoid;}
  .items tbody tr{page-break-inside:avoid;}
  .tot-wrap,.bank-wrap,.sig-row,.baht-words{page-break-inside:avoid;}
  @page{size:A4 portrait;margin:0;}
}

/* Repeated page header for print pages 2+ */
.rpt-hdr {
  display: none;
  position: running(repeatHeader);
}
@media print {
  @page { 
    size: A4 portrait; 
    margin: 12mm 14mm 10mm;
    @top-center { content: element(repeatHeader); }
  }
  .rpt-hdr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1.5px solid #112D5E;
    padding-bottom: 6px;
    margin-bottom: 8px;
    font-size: 8pt;
    width: 100%;
  }
  .rpt-hdr img { height: 20px; }
  .rpt-hdr-r { text-align: right; font-size: 7.5pt; color: #555; }
  .rpt-hdr-num { font-weight: 700; color: #0D1B2A; }
  .sheet { box-shadow: none; padding: 0; background: #fff; }
  .sheet-inner { padding: 0; }
}
</style>
</head>
<body>
<div class="toolbar">
  <div class="tb-t"><strong style="color:#fff;">{doc.document_number}</strong><span style="color:#555;margin:0 8px;">—</span><span style="color:#888;font-size:12px;">{doc.customers?.company_name}</span></div>
  <a href={`/documents/${id}`} class="tbtn t-back">← กลับ</a>
  <button class="tbtn t-print" onclick="window.print()">พิมพ์ / บันทึก PDF</button>
</div>
<div class="wrap">
<div class="sheet">
  {doc.status==='draft' && <div class="wm">DRAFT</div>}
  <div class="hdr">
    <div class="hdr-l">
      <img class="logo" src={LOGO} alt="TNC"/>
      <div class="co-name">ห้างหุ้นส่วนจำกัด ธนชัย 2018 (สำนักงานใหญ่)</div>
      <div class="co-addr">54/6 หมู่ 8 ตำบลบางแก้ว อำเภอบางพลี จังหวัดสมุทรปราการ 10540<br/>โทรศัพท์ 02-XXX-XXXX &emsp; อีเมล: thanachai2018@gmail.com</div>
      <div class="co-tax">เลขประจำตัวผู้เสียภาษีอากร 0113561003884</div>
    </div>
    <div class="hdr-r">
      <span class="doc-type">{doc.document_types?.name_th}</span>
      <span class="doc-bar">{doc.document_types?.name_en || doc.document_types?.code}</span>
      {doc.status==='draft' && <div style="margin-top:8px;"><div class="draft-stamp">DRAFT</div></div>}
    </div>
  </div>
  <table class="info-tbl">
    <tr>
      <td style="width:50%"><span class="lbl">รหัสลูกค้า: </span><span class="val mono">{doc.customers?.customer_code}</span></td>
      <td style="width:50%"><span class="lbl">วันที่ / Date: </span><span class="val">{thaiDate(doc.issue_date)}</span></td>
    </tr>
    <tr><td colspan="2"><span class="lbl">ชื่อลูกค้า: </span><span class="val">{doc.customers?.company_name}</span></td></tr>
    <tr>
      <td><span class="lbl">ที่อยู่: </span><span class="val">{doc.customers?.address||'—'}</span></td>
      <td>
        <div><span class="lbl">เลขที่เอกสาร / No: </span><span class="val mono">{doc.document_number}</span></div>
        {doc.reference_po && <div><span class="lbl">P/O: </span><span class="val mono">{doc.reference_po}</span></div>}
        {isInvoice && doc.due_date && <div><span class="lbl">กำหนดชำระ: </span><span class="val">{thaiDate(doc.due_date)}</span></div>}
        {doc.payment_condition && <div style="margin-top:4px;"><div class="lbl">เงื่อนไขการชำระเงิน:</div><div class="pay">{doc.payment_condition}</div></div>}
        {isQuotation && doc.due_date && <div class="valid-until">⚠ ราคานี้มีผลถึง: {thaiDate(doc.due_date)}</div>}
      </td>
    </tr>
    <tr>
      <td><span class="lbl">โทรศัพท์: </span><span class="val">{doc.customers?.phone||'—'}</span></td>
      <td><span class="lbl">เลขประจำตัวผู้เสียภาษี: </span><span class="val mono">{doc.customers?.tax_id||'—'}</span></td>
    </tr>
  </table>
  <table class="items">
    <thead>
      <tr>
        <th style="width:34px;">ลำดับ</th>
        <th style="width:42px;">รหัส</th>
        <th class="tl">รายการ</th>
        <th style="width:52px;">จำนวน</th>
        <th style="width:44px;">หน่วย</th>
        <th style="width:86px;">หน่วยละ</th>
        <th style="width:94px;">จำนวนเงิน</th>
      </tr>
    </thead>
    <tbody>
      {doc.categories.map((cat: any) => {
        const items = itemsByCategory[cat.id] || [];
        const catTotal = items.filter((i:any)=>!i.is_subtotal_row).reduce((s:number,i:any)=>s+Number(i.amount||0),0);
        return (
          <Fragment>
            <tr class="row-cat">
              <td colspan="6">{cat.category_number}. {cat.name_th}</td>
              <td class="tr">{fmt(catTotal)}</td>
            </tr>
            {items.map((item: any) => {
              if (item.is_subtotal_row) return (
                <tr class="row-sub">
                  <td colspan="6" class="sub-lbl">{item.description_th}</td>
                  <td class="tr tw">{fmt(item.amount)}</td>
                </tr>
              );
              const dots = (item.item_number||'').split('.').length-1;
              const isSubCat = dots===1 && !item.quantity && !item.unit_price;
              if (isSubCat) return (
                <tr class="row-subcat">
                  <td>{item.item_number}</td><td>{item.item_code||''}</td>
                  <td colspan="5">{item.description_th}</td>
                </tr>
              );
              return (
                <tr class="row-item">
                  <td class="tc">{item.item_number||''}</td>
                  <td class="tc">{item.item_code||''}</td>
                  <td style={dots>=2?'padding-left:18px;':''}>{item.description_th}</td>
                  <td class="tr">{item.quantity>0?Number(item.quantity).toLocaleString('th-TH'):'—'}</td>
                  <td class="tc">{item.unit_th||''}</td>
                  <td class="tr">{item.unit_price>0?fmt(item.unit_price):'—'}</td>
                  <td class="tr tw">{item.amount>0?fmt(item.amount):'—'}</td>
                </tr>
              );
            })}
          </Fragment>
        );
      })}
    </tbody>
  </table>
  <div class="tot-wrap">
    <table class="tot-tbl">
      <tr><td class="tt-l">รวมจำนวนเงิน</td><td class="tt-r">{fmt(doc.subtotal)} บาท</td></tr>
      {doc.discount_design>0 && <tr><td class="tt-l">ส่วนลดค่าแบบ</td><td class="tt-r">- {fmt(doc.discount_design)} บาท</td></tr>}
      {doc.discount_trade>0 && <tr><td class="tt-l">ส่วนลดการค้า</td><td class="tt-r">- {fmt(doc.discount_trade)} บาท</td></tr>}
      <tr><td class="tt-l">ราคาก่อน VAT</td><td class="tt-r">{fmt(doc.price_before_vat)} บาท</td></tr>
      <tr><td class="tt-l">ภาษีมูลค่าเพิ่ม 7%</td><td class="tt-r">{fmt(doc.vat_amount)} บาท</td></tr>
      <tr class="grand"><td class="tt-l">จำนวนเงินรวมทั้งสิ้น</td><td class="tt-r">{fmt(doc.total_amount)} บาท</td></tr>
    </table>
  </div>
  <div class="baht-words">จำนวนเงินเป็นตัวหนังสือ: {bahtText(doc.total_amount)}</div>
  {doc.notes && <div class="notes-box"><strong>หมายเหตุ / Remarks</strong><p>{doc.notes}</p></div>}
  <div class="sig-note">ห้างหุ้นส่วนจำกัด ธนชัย 2018 หวังว่าจะได้รับการพิจารณาจากท่าน</div>
  <div class="sig-row">
    <div class="sig-cell"><div class="sig-line"></div><div class="sig-lbl">ลงชื่อผู้เสนอราคา ........................................<br/>วันที่ ......../......../........</div></div>
    <div class="sig-cell"><div class="sig-line"></div><div class="sig-lbl">ลงชื่อผู้สั่งซื้อ ........................................<br/>วันที่ ......../......../........</div></div>
  </div>
  <div class="bank-wrap">
    <div class="bank-box">
      <div class="bank-title">ข้อมูลการชำระเงิน / Payment Information</div>
      <div class="bank-cols">
        <div class="bank-col">
          <div><span class="bank-lbl">ธนาคาร / Bank: </span><span class="bank-val">ธนาคารกสิกรไทย (Kasikorn Bank)</span></div>
          <div><span class="bank-lbl">สาขา / Branch: </span><span class="bank-val">เมกา บางนา 2 (Mega Bangna 2)</span></div>
          <div><span class="bank-lbl">Swift Code: </span><span class="bank-val">KASITHBK</span></div>
          <div><span class="bank-lbl">รหัสธนาคาร: </span><span class="bank-val">004</span></div>
        </div>
        <div class="bank-col">
          <div><span class="bank-lbl">ประเภทบัญชี: </span><span class="bank-val">ออมทรัพย์ (Saving)</span></div>
          <div><span class="bank-lbl">ชื่อบัญชี: </span><span class="bank-val">ห้างหุ้นส่วนจำกัด ธนชัย 2018</span></div>
          <div style="margin-top:2px;"><span class="bank-lbl">เลขที่บัญชี: </span><span class="bank-acc">051-1-72646-8</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
</body>
</html>
