---
import { getDocument, logAction, publishDocument, deleteDocument } from '../../../lib/documents';
const user = Astro.locals.user;
const { id } = Astro.params;
const doc = await getDocument(id!);
if (!doc) return Astro.redirect('/documents/dashboard');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action') as string;
  if (action === 'publish' && user.role === 'superadmin') {
    await publishDocument(id!, user.id);
    return Astro.redirect(`/documents/${id}`);
  }
  if (action === 'delete' && user.role === 'superadmin') {
    await deleteDocument(id!, user.id);
    return Astro.redirect('/documents/dashboard');
  }
}

await logAction(id!, 'view', user.id);

function thaiDate(s: string) {
  if (!s) return '—';
  const d = new Date(s);
  const m = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
  return `${d.getDate()} ${m[d.getMonth()]} ${d.getFullYear()+543}`;
}
function money(n: number) {
  return Number(n||0).toLocaleString('th-TH', { minimumFractionDigits: 2 });
}

const itemsByCategory: Record<string, any[]> = {};
doc.categories.forEach((cat: any) => {
  itemsByCategory[cat.id] = doc.items.filter((i: any) => i.category_id === cat.id);
});

function parseInstallments(cond: string, total: number) {
  if (!cond) return [];
  const lines = cond.split('\n').map((l: string) => l.trim()).filter(Boolean);
  const result: {pct: number, label: string, amount: number}[] = [];
  for (const line of lines) {
    const m = line.match(/^(\d+(?:\.\d+)?)%\s*(.*)/);
    if (m) {
      const pct = parseFloat(m[1]);
      result.push({ pct, label: m[2] || line, amount: Math.round(total * pct / 100 * 100) / 100 });
    }
  }
  const totalPct = result.reduce((s, r) => s + r.pct, 0);
  return totalPct > 0 && totalPct <= 100 && result.length > 1 ? result : [];
}

const installments = parseInstallments(doc.payment_condition || '', doc.total_amount || 0);
const hasInstallments = installments.length > 0;
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta name="robots" content="noindex,nofollow"/>
  <title>{doc.document_number} — TNC</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#F7F6F3;--white:#fff;--border:#E0DDD7;--b2:#ECEAE5;
      --text:#1A1814;--t2:#6B6860;--t3:#AEABA4;
      --gold:#C9A96E;--gbg:#FAF5EC;--gborder:#E8D5A8;
      --green:#2D7A4F;--grbg:#EDF7F0;--grborder:#C5E8D2;
      --red:#B94040;--redbg:#FEF2F2;
    }
    body{font-family:'Plus Jakarta Sans','Noto Sans Thai',sans-serif;background:var(--bg);color:var(--text);}
    .topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 20px;height:54px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:30;}
    .back{font-size:12px;color:var(--t2);text-decoration:none;padding:7px 12px;border:1px solid var(--border);border-radius:5px;white-space:nowrap;flex-shrink:0;}
    .tb-docnum{font-size:13px;font-weight:700;font-family:monospace;white-space:nowrap;}
    .tb-cust{font-size:12px;color:var(--t2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
    .tb-actions{display:flex;gap:6px;align-items:center;flex-shrink:0;}
    .btn{padding:7px 13px;border-radius:5px;font-size:11.5px;font-weight:700;font-family:inherit;cursor:pointer;border:none;letter-spacing:.04em;text-transform:uppercase;text-decoration:none;display:inline-flex;align-items:center;gap:5px;transition:all .15s;white-space:nowrap;min-height:38px;}
    .btn-ol{background:transparent;color:var(--t2);border:1px solid var(--border);}
    .btn-green{background:var(--green);color:#fff;}
    .btn-red{background:var(--red);color:#fff;}
    .spill{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;flex-shrink:0;}
    .sdot{width:6px;height:6px;border-radius:50%;}
    .spill-draft{background:var(--bg);color:var(--t3);border:1px solid var(--border);}
    .spill-draft .sdot{background:var(--t3);}
    .spill-pub{background:var(--grbg);color:var(--green);border:1px solid var(--grborder);}
    .spill-pub .sdot{background:var(--green);}
    .layout{display:grid;grid-template-columns:1fr 270px;min-height:calc(100dvh - 54px);}
    .main{padding:24px;border-right:1px solid var(--border);min-width:0;}
    .aside{padding:20px;background:var(--white);}
    .info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;}
    .icard{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:16px 18px;}
    .icard-lbl{font-size:9.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);margin-bottom:6px;}
    .icard-val{font-size:14px;font-weight:600;}
    .icard-sub{font-size:12px;color:var(--t2);margin-top:3px;line-height:1.6;}
    .cat-sec{margin-bottom:16px;}
    .cat-hd{display:flex;align-items:center;gap:8px;padding:9px 14px;background:var(--text);color:var(--bg);border-radius:5px 5px 0 0;font-size:13px;font-weight:600;}
    .cat-badge{background:rgba(255,255,255,.15);padding:2px 8px;border-radius:3px;font-size:10px;}
    .cat-total{margin-left:auto;font-size:12px;opacity:.8;}
    .tbl-wrap{overflow-x:auto;background:var(--white);border:1px solid var(--border);border-top:none;border-radius:0 0 5px 5px;}
    table{width:100%;border-collapse:collapse;min-width:480px;}
    thead th{padding:8px 10px;background:var(--bg);font-size:9px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.09em;text-align:left;border-bottom:1px solid var(--border);}
    thead th.r{text-align:right;}thead th.c{text-align:center;}
    tbody tr{border-bottom:1px solid var(--b2);}tbody tr:last-child{border-bottom:none;}tbody tr.sub-row{background:var(--bg);}
    td{padding:9px 10px;font-size:12.5px;color:var(--t2);}
    td.r{text-align:right;font-weight:600;color:var(--text);}td.c{text-align:center;}
    td.mono{font-family:monospace;font-size:11px;color:var(--t3);}td.desc{color:var(--text);}
    td.sub-lbl{text-align:right;font-weight:700;color:var(--t2);font-size:11.5px;}td.sub-val{text-align:right;font-weight:700;color:var(--text);}
    .no-items{padding:24px;text-align:center;color:var(--t3);font-size:13px;}
    .notes-box{margin-top:14px;background:var(--white);border:1px solid var(--border);border-radius:6px;padding:16px 18px;}
    .notes-lbl{font-size:9.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--t3);margin-bottom:8px;}
    .notes-txt{font-size:13px;color:var(--t2);white-space:pre-line;line-height:1.7;}
    .inst-card{background:var(--gbg);border:1px solid var(--gborder);border-radius:6px;padding:14px 16px;margin-bottom:16px;}
    .inst-title{font-size:9.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#8B6914;margin-bottom:10px;}
    .inst-row{display:flex;align-items:center;padding:7px 0;border-bottom:1px dashed var(--gborder);}
    .inst-row:last-of-type{border-bottom:none;}
    .inst-pct{font-size:11px;font-weight:700;color:var(--gold);min-width:36px;}
    .inst-label{font-size:12px;color:var(--t2);flex:1;padding:0 8px;}
    .inst-amount{font-size:13px;font-weight:700;color:var(--text);}
    .inst-gen-btn{width:100%;margin-top:10px;padding:9px;background:var(--text);color:var(--bg);border:none;border-radius:4px;font-size:11.5px;font-weight:700;font-family:inherit;cursor:pointer;letter-spacing:.05em;text-transform:uppercase;}
    .inst-gen-btn:hover{opacity:.85;}
    .panel-sec{margin-bottom:20px;}
    .panel-title{font-size:9.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);margin-bottom:12px;}
    .sum-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--b2);}
    .sum-row:last-child{border-bottom:none;}
    .sum-row.total{border-top:2px solid var(--text);border-bottom:none;padding-top:10px;margin-top:4px;}
    .sum-lbl{font-size:12.5px;color:var(--t2);}
    .sum-val{font-size:12.5px;font-weight:600;}
    .sum-val.big{font-size:20px;font-weight:300;letter-spacing:-.02em;}
    .divider{border:none;border-top:1px solid var(--b2);margin:16px 0;}
    .action-list{display:flex;flex-direction:column;gap:8px;}
    .aitem{display:flex;align-items:center;gap:10px;padding:11px 13px;background:var(--bg);border:1px solid var(--border);border-radius:6px;text-decoration:none;cursor:pointer;transition:border-color .15s;width:100%;text-align:left;font-family:inherit;}
    .aitem:hover{border-color:var(--text);}
    .aitem.danger{background:var(--redbg);border-color:#FECACA;}
    .aitem.danger:hover{border-color:var(--red);}
    .aicon{width:30px;height:30px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
    .aicon-pdf{background:#FEF2F2;color:var(--red);}
    .aicon-edit{background:var(--gbg);color:var(--gold);}
    .aicon-pub{background:var(--grbg);color:var(--green);}
    .aicon-del{background:#FEF2F2;color:var(--red);}
    .aicon-url{background:#E8F4FD;color:#1A6FA8;font-size:11px;font-weight:700;}
    .atext-title{font-size:13px;font-weight:600;color:var(--text);}
    .atext-sub{font-size:11px;color:var(--t3);margin-top:1px;}
    .warn-box{background:#FFFBEB;border:1px solid #FDE68A;border-radius:5px;padding:10px 12px;font-size:12px;color:#92400E;margin-bottom:12px;}
    .warn-box strong{display:block;margin-bottom:2px;}
    .meta-info{font-size:11.5px;color:var(--t3);line-height:1.8;}
    .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center;}
    .modal-overlay.show{display:flex;}
    .modal{background:var(--white);border-radius:8px;padding:24px;width:360px;max-width:92vw;box-shadow:0 20px 60px rgba(0,0,0,.25);}
    .modal-title{font-size:14px;font-weight:700;margin-bottom:4px;}
    .modal-sub{font-size:12px;color:var(--t3);margin-bottom:16px;}
    .modal-opt{display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid var(--border);border-radius:5px;cursor:pointer;margin-bottom:8px;transition:border-color .15s;}
    .modal-opt:hover{border-color:var(--gold);}
    .modal-opt input[type=radio]{accent-color:var(--text);width:16px;height:16px;flex-shrink:0;}
    .modal-opt-main{font-size:12.5px;font-weight:600;}
    .modal-opt-sub{font-size:11px;color:var(--t3);}
    .modal-btns{display:flex;gap:8px;margin-top:16px;}
    .modal-cancel{flex:1;padding:9px;border:1px solid var(--border);background:transparent;border-radius:4px;font-size:12px;font-weight:600;font-family:inherit;cursor:pointer;}
    .modal-confirm{flex:2;padding:9px;background:var(--text);color:var(--bg);border:none;border-radius:4px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer;letter-spacing:.04em;text-transform:uppercase;}
    @media(max-width:768px){
      .topbar{padding:0 14px;gap:6px;}.tb-cust{display:none;}.tb-actions .spill{display:none;}
      .layout{display:block;}.main{padding:14px 12px;border-right:none;}
      .aside{border-top:1px solid var(--border);padding:16px 12px;}
      .info-grid{grid-template-columns:1fr;}
    }
  </style>
</head>
<body>
  <div class="topbar">
    <a href="/documents/dashboard" class="back">← กลับ</a>
    <div class="tb-docnum">{doc.document_number}</div>
    <div class="tb-cust">— {doc.customers?.company_name}</div>
    <div class="tb-actions">
      <span class={`spill spill-${doc.status === 'published' ? 'pub' : 'draft'}`}>
        <span class="sdot"></span>{doc.status === 'draft' ? 'Draft' : 'Published'}
      </span>
      <a href={`/documents/${id}/print`} target="_blank" class="btn btn-ol">PDF</a>
      {doc.status === 'draft' && user.role === 'superadmin' && (
        <form method="POST" style="display:inline;">
          <input type="hidden" name="action" value="publish"/>
          <button type="submit" class="btn btn-green"
            onclick="return confirm('ออกเอกสารนี้? จะไม่สามารถแก้ไขได้หลังจากนี้')">ออกเอกสาร</button>
        </form>
      )}
      {user.role === 'superadmin' && (
        <form method="POST" style="display:inline;">
          <input type="hidden" name="action" value="delete"/>
          <button type="submit" class="btn btn-red"
            onclick={`return confirm('ลบเอกสาร ${doc.document_number}? ไม่สามารถกู้คืนได้')`}>ลบ</button>
        </form>
      )}
    </div>
  </div>

  <div class="layout">
    <div class="main">
      <div class="info-grid">
        <div class="icard">
          <div class="icard-lbl">ลูกค้า</div>
          <div class="icard-val">{doc.customers?.company_name}</div>
          <div class="icard-sub">{doc.customers?.customer_code}<br/>{doc.customers?.address}</div>
        </div>
        <div class="icard">
          <div class="icard-lbl">ข้อมูลเอกสาร</div>
          <div class="icard-val">{doc.document_types?.name_th}</div>
          <div class="icard-sub">
            วันที่ออก: {thaiDate(doc.issue_date)}<br/>
            {doc.due_date ? `วันครบกำหนด: ${thaiDate(doc.due_date)}` : ''}
            {doc.reference_po ? `P/O: ${doc.reference_po}` : ''}
          </div>
        </div>
        {doc.payment_condition && (
          <div class="icard" style="grid-column:span 2;">
            <div class="icard-lbl">เงื่อนไขการชำระเงิน</div>
            <div class="icard-sub" style="white-space:pre-line;">{doc.payment_condition}</div>
          </div>
        )}
      </div>

      {doc.categories.length === 0 ? (
        <div class="no-items">ยังไม่มีรายการงานในเอกสารนี้</div>
      ) : (
        doc.categories.map((cat: any) => {
          const items = itemsByCategory[cat.id] || [];
          const catTotal = items.filter((i:any)=>!i.is_subtotal_row).reduce((s:number,i:any)=>s+Number(i.amount||0),0);
          return (
            <div class="cat-sec">
              <div class="cat-hd">
                <span class="cat-badge">หมวด {cat.category_number}</span>
                {cat.name_th}
                <span class="cat-total">฿{money(catTotal)}</span>
              </div>
              <div class="tbl-wrap">
                <table>
                  <thead>
                    <tr>
                      <th style="width:40px;">#</th><th style="width:48px;">รหัส</th>
                      <th>รายการ</th><th class="r" style="width:56px;">จำนวน</th>
                      <th class="c" style="width:48px;">หน่วย</th>
                      <th class="r" style="width:84px;">หน่วยละ</th>
                      <th class="r" style="width:96px;">จำนวนเงิน</th>
                    </tr>
                  </thead>
                  <tbody>
                    {items.map((item: any) => {
                      if (item.is_subtotal_row) return (
                        <tr class="sub-row">
                          <td colspan="6" class="sub-lbl">{item.description_th}</td>
                          <td class="sub-val">฿{money(item.amount)}</td>
                        </tr>
                      );
                      return (
                        <tr>
                          <td class="mono">{item.item_number}</td>
                          <td class="mono c">{item.item_code||''}</td>
                          <td class="desc">{item.description_th}</td>
                          <td class="r">{item.quantity>0?item.quantity:'—'}</td>
                          <td class="c">{item.unit_th}</td>
                          <td class="r">{item.unit_price>0?money(item.unit_price):'—'}</td>
                          <td class="r">{item.amount>0?money(item.amount):'—'}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          );
        })
      )}
      {doc.notes && (
        <div class="notes-box">
          <div class="notes-lbl">หมายเหตุ</div>
          <div class="notes-txt">{doc.notes}</div>
        </div>
      )}
    </div>

    <div class="aside">
      <div class="panel-sec">
        <div class="panel-title">สรุปราคา</div>
        <div class="sum-row"><span class="sum-lbl">รวมจำนวนเงิน</span><span class="sum-val">฿{money(doc.subtotal)}</span></div>
        {doc.discount_design>0 && <div class="sum-row"><span class="sum-lbl">ส่วนลดค่าแบบ</span><span class="sum-val">-฿{money(doc.discount_design)}</span></div>}
        {doc.discount_trade>0 && <div class="sum-row"><span class="sum-lbl">ส่วนลดการค้า</span><span class="sum-val">-฿{money(doc.discount_trade)}</span></div>}
        <div class="sum-row"><span class="sum-lbl">ราคาก่อน VAT</span><span class="sum-val">฿{money(doc.price_before_vat)}</span></div>
        <div class="sum-row"><span class="sum-lbl">VAT 7%</span><span class="sum-val">฿{money(doc.vat_amount)}</span></div>
        <div class="sum-row total">
          <span class="sum-lbl" style="font-weight:700;font-size:13px;">ยอดรวมทั้งสิ้น</span>
          <span class="sum-val big">฿{money(doc.total_amount)}</span>
        </div>
      </div>

      {hasInstallments && (
        <div class="inst-card">
          <div class="inst-title">📋 งวดการชำระเงิน</div>
          {installments.map((inst: any) => (
            <div class="inst-row">
              <span class="inst-pct">{inst.pct}%</span>
              <span class="inst-label">{inst.label}</span>
              <span class="inst-amount">฿{money(inst.amount)}</span>
            </div>
          ))}
          <button class="inst-gen-btn" id="genInstBtn">สร้างใบแจ้งหนี้งวด →</button>
        </div>
      )}

      <hr class="divider"/>

      <div class="panel-sec">
        <div class="panel-title">การดำเนินการ</div>
        {doc.status==='draft' && (
          <div class="warn-box"><strong>เอกสารนี้เป็น Draft</strong>ยังไม่ได้ออกเอกสารอย่างเป็นทางการ</div>
        )}
        <div class="action-list">
          <a href={`/documents/${id}/print`} target="_blank" class="aitem">
            <div class="aicon aicon-pdf">PDF</div>
            <div><div class="atext-title">Preview & พิมพ์</div><div class="atext-sub">เปิดหน้า PDF</div></div>
          </a>
          <button onclick="copyLink()" class="aitem">
            <div class="aicon aicon-url">URL</div>
            <div><div class="atext-title">คัดลอกลิงก์</div><div class="atext-sub" id="copy-hint">ส่งให้ลูกค้าดูเอกสาร</div></div>
          </button>
          {(doc.status==='draft' || user.role==='superadmin') && (
            <a href={`/documents/${id}/edit`} class="aitem">
              <div class="aicon aicon-edit">✎</div>
              <div><div class="atext-title">แก้ไขเอกสาร</div><div class="atext-sub">แก้ไขรายการและข้อมูล</div></div>
            </a>
          )}
          {doc.status==='draft' && user.role==='superadmin' && (
            <form method="POST">
              <input type="hidden" name="action" value="publish"/>
              <button type="submit" class="aitem" style="background:var(--grbg);border-color:var(--grborder);"
                onclick="return confirm('ออกเอกสารนี้?')">
                <div class="aicon aicon-pub">✓</div>
                <div><div class="atext-title" style="color:var(--green);">ออกเอกสาร</div><div class="atext-sub">เปลี่ยนสถานะเป็น Published</div></div>
              </button>
            </form>
          )}
          {user.role==='superadmin' && (
            <form method="POST">
              <input type="hidden" name="action" value="delete"/>
              <button type="submit" class="aitem danger"
                onclick={`return confirm('ลบเอกสาร ${doc.document_number}? ไม่สามารถกู้คืนได้')`}>
                <div class="aicon aicon-del">🗑</div>
                <div><div class="atext-title" style="color:var(--red);">ลบเอกสาร</div><div class="atext-sub">ลบถาวร ไม่สามารถกู้คืนได้</div></div>
              </button>
            </form>
          )}
        </div>
      </div>

      <hr class="divider"/>
      <div class="panel-title">ข้อมูลเพิ่มเติม</div>
      <div class="meta-info">
        สร้างโดย: {doc.tnc_users?.full_name||'—'}<br/>
        ประเภท: {doc.document_types?.name_th}<br/>
        ID: <span style="font-family:monospace;font-size:10px;">{id?.substring(0,8)}...</span>
      </div>
    </div>
  </div>

  {hasInstallments && (
    <div class="modal-overlay" id="instModal">
      <div class="modal">
        <div class="modal-title">สร้างใบแจ้งหนี้งวด</div>
        <div class="modal-sub">เลือกงวดที่ต้องการสร้างใบแจ้งหนี้</div>
        {installments.map((inst: any, idx: number) => (
          <label class="modal-opt">
            <input type="radio" name="instChoice" value={idx}/>
            <div>
              <div class="modal-opt-main">{inst.pct}% — ฿{money(inst.amount)}</div>
              <div class="modal-opt-sub">{inst.label}</div>
            </div>
          </label>
        ))}
        <div class="modal-btns">
          <button class="modal-cancel" id="instCancel">ยกเลิก</button>
          <button class="modal-confirm" id="instConfirm">สร้างใบแจ้งหนี้</button>
        </div>
      </div>
    </div>
  )}

  <script is:inline define:vars={{ installments, docId: id }}>
    var btn = document.getElementById('genInstBtn');
    var modal = document.getElementById('instModal');
    var cancel = document.getElementById('instCancel');
    var confirm2 = document.getElementById('instConfirm');
    if (btn) btn.addEventListener('click', function(){ modal.classList.add('show'); });
    if (cancel) cancel.addEventListener('click', function(){ modal.classList.remove('show'); });
    if (confirm2) confirm2.addEventListener('click', function(){
      var sel = document.querySelector('input[name="instChoice"]:checked');
      if (!sel) { alert('กรุณาเลือกงวด'); return; }
      var inst = installments[parseInt(sel.value)];
      var params = new URLSearchParams({
        from_doc: docId,
        inst_pct: String(inst.pct),
        inst_amount: String(inst.amount),
        inst_label: inst.label,
      });
      window.location.href = '/documents/new?' + params.toString();
    });
    if (modal) modal.addEventListener('click', function(e){ if(e.target===modal) modal.classList.remove('show'); });
  window.copyLink = function() {
    var url = 'https://tncdocument.pages.dev/documents/' + docId + '/print';
    navigator.clipboard.writeText(url).then(function() {
      var hint = document.getElementById('copy-hint');
      if (hint) {
        hint.textContent = 'คัดลอกแล้ว!';
        hint.style.color = '#2D7A4F';
        setTimeout(function() {
          hint.textContent = 'ส่งให้ลูกค้าดูเอกสาร';
          hint.style.color = '';
        }, 2000);
      }
    });
  };
  </script>
</body>
</html>
