---
import { getCustomers } from '../../../lib/documents';
const user = Astro.locals.user;
const customers = await getCustomers();
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>รายชื่อลูกค้า — TNC Documents</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#F8F7F4;--white:#fff;--border:#E2DFD8;--border2:#EDE9E3;--text:#1A1814;--text2:#6B6860;--text3:#AEABA4;}
    body{font-family:'Plus Jakarta Sans','Noto Sans Thai',sans-serif;background:var(--bg);color:var(--text);}
    .topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 40px;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;}
    .topbar-left{display:flex;align-items:center;gap:14px;}
    .back{font-size:12.5px;color:var(--text2);text-decoration:none;padding:6px 12px;border:1px solid var(--border);border-radius:4px;}
    .back:hover{border-color:var(--text);color:var(--text);}
    .topbar-title{font-size:15px;font-weight:600;}
    .btn-new{padding:9px 20px;background:var(--text);color:var(--bg);border:none;border-radius:4px;font-size:12px;font-weight:700;font-family:inherit;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-block;}
    .content{padding:32px 40px;}
    .card{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden;}
    table{width:100%;border-collapse:collapse;}
    thead th{padding:10px 16px;text-align:left;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;background:var(--bg);border-bottom:1px solid var(--border);}
    tbody tr{border-bottom:1px solid var(--border2);cursor:pointer;transition:background .1s;}
    tbody tr:hover{background:#FAFAF8;}
    tbody tr:last-child{border-bottom:none;}
    td{padding:13px 16px;font-size:13px;color:var(--text2);}
    td.strong{color:var(--text);font-weight:600;}
    td.mono{font-family:monospace;font-size:12.5px;color:var(--text);}
    .empty{padding:64px;text-align:center;color:var(--text3);}
    .empty-title{font-size:14px;font-weight:600;color:var(--text2);margin-bottom:6px;}
    .empty-sub{font-size:12.5px;margin-bottom:20px;}
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <a href="/documents/dashboard" class="back">← กลับ</a>
      <div class="topbar-title">รายชื่อลูกค้า ({customers.length})</div>
    </div>
    <a href="/documents/customers/new" class="btn-new">+ เพิ่มลูกค้าใหม่</a>
  </div>
  <div class="content">
    <div class="card">
      {customers.length === 0 ? (
        <div class="empty">
          <div class="empty-title">ยังไม่มีลูกค้าในระบบ</div>
          <div class="empty-sub">เพิ่มลูกค้าใหม่เพื่อเริ่มสร้างเอกสาร</div>
          <a href="/documents/customers/new" class="btn-new">+ เพิ่มลูกค้าแรก</a>
        </div>
      ) : (
        <table>
          <thead>
            <tr>
              <th>รหัสลูกค้า</th>
              <th>ชื่อบริษัท / ลูกค้า</th>
              <th>ผู้ติดต่อ</th>
              <th>โทรศัพท์</th>
              <th>เลขประจำตัวผู้เสียภาษี</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {customers.map((c: any) => (
              <tr onclick={`window.location='/documents/customers/${c.id}'`}>
                <td class="mono">{c.customer_code}</td>
                <td class="strong">{c.company_name}</td>
                <td>{c.contact_name || '—'}</td>
                <td>{c.phone || '—'}</td>
                <td class="mono">{c.tax_id || '—'}</td>
                <td style="text-align:right;">
                  <a href={`/documents/customers/${c.id}`} style="font-size:12px;color:var(--text2);text-decoration:none;">แก้ไข →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</body>
</html>
