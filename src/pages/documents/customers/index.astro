---
import { getCustomers } from '../../../lib/documents';
const user = Astro.locals.user;
const customers = await getCustomers();
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>รายชื่อลูกค้า — TNC</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#F7F6F3;--white:#fff;--border:#E0DDD7;--b2:#ECEAE5;--text:#1A1814;--t2:#6B6860;--t3:#AEABA4;--gold:#C9A96E;}
    body{font-family:'Plus Jakarta Sans','Noto Sans Thai',sans-serif;background:var(--bg);color:var(--text);}
    .topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 24px;height:54px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:10;}
    .back{font-size:12px;color:var(--t2);text-decoration:none;padding:7px 12px;border:1px solid var(--border);border-radius:5px;white-space:nowrap;-webkit-tap-highlight-color:transparent;}
    .back:active{background:var(--bg);}
    .topbar-title{font-size:15px;font-weight:700;flex:1;}
    .btn-new{padding:9px 16px;background:var(--text);color:var(--bg);border:none;border-radius:5px;font-size:12px;font-weight:700;font-family:inherit;letter-spacing:.05em;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-block;white-space:nowrap;-webkit-tap-highlight-color:transparent;min-height:40px;display:inline-flex;align-items:center;}
    .btn-new:active{opacity:.8;}
    .content{padding:20px 16px;}
    .card{background:var(--white);border:1px solid var(--border);border-radius:8px;overflow:hidden;}

    /* Desktop table */
    .tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
    table{width:100%;border-collapse:collapse;min-width:500px;}
    thead th{padding:10px 16px;text-align:left;font-size:9.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.1em;background:var(--bg);border-bottom:1px solid var(--border);}
    tbody tr{border-bottom:1px solid var(--b2);cursor:pointer;transition:background .1s;-webkit-tap-highlight-color:transparent;}
    tbody tr:hover,tbody tr:active{background:#FAFAF8;}
    tbody tr:last-child{border-bottom:none;}
    td{padding:13px 16px;font-size:13px;color:var(--t2);}
    td.strong{color:var(--text);font-weight:600;}
    td.mono{font-family:monospace;font-size:12px;color:var(--text);}

    /* Mobile card list */
    .mob-list{display:none;}
    .mob-item{padding:14px 16px;border-bottom:1px solid var(--b2);cursor:pointer;-webkit-tap-highlight-color:transparent;}
    .mob-item:last-child{border-bottom:none;}
    .mob-item:active{background:var(--bg);}
    .mob-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:4px;}
    .mob-meta{display:flex;gap:12px;flex-wrap:wrap;}
    .mob-tag{font-size:11.5px;color:var(--t2);}
    .mob-code{font-size:11.5px;color:var(--t3);font-family:monospace;}

    .empty{padding:48px 24px;text-align:center;color:var(--t3);}
    .empty-title{font-size:14px;font-weight:600;color:var(--t2);margin-bottom:6px;}
    .empty-sub{font-size:12.5px;margin-bottom:20px;}

    @media(max-width:600px){
      .topbar{padding:0 16px;}
      .topbar-title{font-size:14px;}
      .content{padding:14px 12px;}
      .tbl-wrap{display:none;}
      .mob-list{display:block;}
    }
  </style>
</head>
<body>
  <div class="topbar">
    <a href="/documents/dashboard" class="back">← กลับ</a>
    <div class="topbar-title">รายชื่อลูกค้า ({customers.length})</div>
    <a href="/documents/customers/new" class="btn-new">+ เพิ่มใหม่</a>
  </div>
  <div class="content">
    <div class="card">
      {customers.length === 0 ? (
        <div class="empty">
          <div class="empty-title">ยังไม่มีลูกค้าในระบบ</div>
          <div class="empty-sub">เพิ่มลูกค้าใหม่เพื่อเริ่มสร้างเอกสาร</div>
          <a href="/documents/customers/new" class="btn-new">+ เพิ่มลูกค้าแรก</a>
        </div>
      ) : (
        <>
          <div class="tbl-wrap">
            <table>
              <thead>
                <tr>
                  <th>รหัสลูกค้า</th>
                  <th>ชื่อบริษัท / ลูกค้า</th>
                  <th>ผู้ติดต่อ</th>
                  <th>โทรศัพท์</th>
                  <th>เลขภาษี</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {customers.map((c: any) => (
                  <tr onclick={`window.location='/documents/customers/${c.id}'`}>
                    <td class="mono">{c.customer_code}</td>
                    <td class="strong">{c.company_name}</td>
                    <td>{c.contact_name || '—'}</td>
                    <td>{c.phone || '—'}</td>
                    <td class="mono">{c.tax_id || '—'}</td>
                    <td style="text-align:right;"><a href={`/documents/customers/${c.id}`} style="font-size:12px;color:var(--t2);text-decoration:none;">แก้ไข →</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="mob-list">
            {customers.map((c: any) => (
              <div class="mob-item" onclick={`window.location='/documents/customers/${c.id}'`}>
                <div class="mob-name">{c.company_name}</div>
                <div class="mob-meta">
                  <span class="mob-code">{c.customer_code}</span>
                  {c.contact_name && <span class="mob-tag">{c.contact_name}</span>}
                  {c.phone && <span class="mob-tag">{c.phone}</span>}
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  </div>
</body>
</html>
